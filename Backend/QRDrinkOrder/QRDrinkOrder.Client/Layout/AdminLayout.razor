@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<div class="admin-wrapper">
    <!-- Mobile Sidebar Backdrop -->
    @if (isMobileMenuOpen)
    {
        <div class="admin-sidebar-backdrop" @onclick="CloseMobileMenu"></div>
    }

    <!-- Desktop & Mobile Sidebar -->
    <aside class="admin-sidebar @(isMobileMenuOpen ? "mobile-open" : "")">
        <div class="admin-sidebar-brand">
            <div class="admin-brand-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
                    <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
                </svg>
            </div>
            <div class="admin-brand-text">
                <span class="brand-name">Ngoc UwU</span>
                <span class="brand-role">Admin Panel</span>
            </div>
        </div>

        <nav class="admin-nav">
            <div class="admin-nav-section-label">Tổng quan</div>
            <a href="/admin/dashboard" class="admin-nav-item @(IsActive("/admin/dashboard") ? "active" : "")">
                <span class="nav-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                </span>
                <span>Dashboard</span>
            </a>

            <div class="admin-nav-section-label">Quản lý</div>
            <a href="/admin/menu" class="admin-nav-item @(IsActive("/admin/menu") ? "active" : "")">
                <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/></svg></span>
                <span>Thực đơn</span>
            </a>
            <a href="/admin/orders" class="admin-nav-item @(IsActive("/admin/orders") ? "active" : "")">
                <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></span>
                <span>Đơn hàng</span>
            </a>
            <a href="/admin/accounts" class="admin-nav-item @(IsActive("/admin/accounts") ? "active" : "")">
                <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
                <span>Nhân sự</span>
            </a>
            <a href="/admin/bank-accounts" class="admin-nav-item @(IsActive("/admin/bank-accounts") ? "active" : "")">
                <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></span>
                <span>Thanh toán</span>
            </a>
            <a href="/admin/settings" class="admin-nav-item @(IsActive("/admin/settings") ? "active" : "")">
                <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></span>
                <span>Cấu hình</span>
            </a>
            <a href="/admin/reviews" class="admin-nav-item @(IsActive("/admin/reviews") ? "active" : "")">
                <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg></span>
                <span>Đánh giá</span>
            </a>

            <div class="admin-nav-section-label">Marketing</div>
            <a href="/admin/coupons" class="admin-nav-item @(IsActive("/admin/coupons") ? "active" : "")">
                <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg></span>
                <span>Coupon</span>
            </a>
            <a href="/admin/promotions" class="admin-nav-item @(IsActive("/admin/promotions") ? "active" : "")">
                <span class="nav-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></span>
                <span>Banners</span>
            </a>
            <a href="/admin/loyalty-config" class="admin-nav-item @(IsActive("/admin/loyalty-config") ? "active" : "")">
                <span class="nav-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                </span>
                <span>Tích điểm</span>
            </a>
        </nav>

        <div class="admin-sidebar-footer">
            <button class="admin-exit-btn" @onclick="GoBack">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                Thoát Admin
            </button>
        </div>
    </aside>

    <!-- Mobile Top Header -->
    <header class="admin-mobile-header">
        <div class="admin-mobile-header-inner">
            <button class="admin-mobile-menu-btn" @onclick="ToggleMobileMenu">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>
            <div class="admin-brand-icon" style="width:32px;height:32px;border-radius:8px;flex-shrink:0;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
                </svg>
            </div>
            <span class="admin-mobile-title">Ngoc UwU Admin</span>
        </div>
    </header>

    <!-- Main Content -->
    <main class="admin-main">
        @Body
    </main>
</div>

@code {
    private bool isMobileMenuOpen = false;

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += (s, e) => { isMobileMenuOpen = false; StateHasChanged(); };
    }

    private bool IsActive(string path)
    {
        var currentPath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        return $"/{currentPath}".StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }

    private void ToggleMobileMenu() => isMobileMenuOpen = !isMobileMenuOpen;
    private void CloseMobileMenu() => isMobileMenuOpen = false;

    private void GoBack()
    {
        isMobileMenuOpen = false;
        NavigationManager.NavigateTo("/account");
    }
}

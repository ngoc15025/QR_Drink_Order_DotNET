@using QRDrinkOrder.Shared.DTOs.Responses

<div class="admin-table-card">
    <table class="admin-table">
        <thead>
            <tr>
                <th width="80">ID</th>
                <th>Tên Danh Mục</th>
                <th class="text-center">Thứ tự</th>
                <th>Trạng thái</th>
                <th class="text-end">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cat in Categories.OrderBy(c => c.DisplayOrder))
            {
                <tr>
                    <td class="px-4 py-3 text-secondary" style="font-weight: 500;">#@cat.CategoryId</td>
                    <td class="py-3 fw-bold text-dark">@cat.CategoryName</td>
                    <td class="py-3 text-center">
                        <span class="admin-badge badge-secondary rounded-pill px-3 py-1">@cat.DisplayOrder</span>
                    </td>
                    <td class="py-3">
                        @if (cat.IsActive)
                        {
                            <span class="admin-badge badge-success">Hoạt động</span>
                        }
                        else
                        {
                            <span class="admin-badge badge-danger">Đã ẩn</span>
                        }
                    </td>
                    <td class="text-end">
                        <button class="btn-admin-action btn-action-secondary btn-action-sm" @onclick="() => OnEditCategory.InvokeAsync(cat)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16"><path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/><path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5v11z"/></svg>
                            Sửa
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter]
    public List<CategoryDto> Categories { get; set; } = new();

    [Parameter]
    public EventCallback<CategoryDto> OnEditCategory { get; set; }
}

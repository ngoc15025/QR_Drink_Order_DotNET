@using QRDrinkOrder.Shared.DTOs.Requests
@using QRDrinkOrder.Shared.DTOs.Responses
@using QRDrinkOrder.Shared.Enums
@using System.Net.Http.Headers
@inject QRDrinkOrder.Client.Services.MenuApiClient MenuApi
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

<div class="modal fade show d-block modal-glass" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content modal-content-premium">
            <div class="modal-header modal-header-premium">
                <h5 class="modal-title modal-title-premium">@(EditingDrinkId == 0 ? "Thêm Món Mới" : "Cập Nhật Món")</h5>
                <button type="button" class="btn-close" @onclick="OnClose"></button>
            </div>
            <div class="modal-body p-4">
                <EditForm Model="@Model" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label form-label-premium">Tên món (Tiếng Việt) *</label>
                            <InputText class="form-control form-control-premium" @bind-Value="Model.NameVi" />
                            <ValidationMessage For="@(() => Model.NameVi)" class="text-danger small mt-1" />
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label form-label-premium">Tên món (Tiếng Anh) *</label>
                            <InputText class="form-control form-control-premium" @bind-Value="Model.NameEn" />
                            <ValidationMessage For="@(() => Model.NameEn)" class="text-danger small mt-1" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label form-label-premium">Mô tả (Tiếng Việt)</label>
                            <InputTextArea class="form-control form-control-premium" @bind-Value="Model.DescriptionVi" rows="2" placeholder="Nhập mô tả..." />
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label form-label-premium">Mô tả (Tiếng Anh)</label>
                            <InputTextArea class="form-control form-control-premium" @bind-Value="Model.DescriptionEn" rows="2" placeholder="Enter description..." />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label form-label-premium">Danh mục *</label>
                            <InputSelect class="form-select form-control-premium" @bind-Value="Model.CategoryId">
                                <option value="0">-- Chọn danh mục --</option>
                                @foreach (var c in Categories)
                                {
                                    <option value="@c.CategoryId">@c.CategoryName</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => Model.CategoryId)" class="text-danger small mt-1" />
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label form-label-premium">Giá bán (VND) *</label>
                            <InputNumber class="form-control form-control-premium" @bind-Value="Model.BasePrice" />
                            <ValidationMessage For="@(() => Model.BasePrice)" class="text-danger small mt-1" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label form-label-premium">Phân loại</label>
                            <InputSelect class="form-select form-control-premium" @bind-Value="Model.TemperatureType">
                                <option value="@DrinkTemperature.Hot">Nóng (Hot)</option>
                                <option value="@DrinkTemperature.Iced">Lạnh (Iced)</option>
                                <option value="@DrinkTemperature.Both">Tùy chọn (Cả hai)</option>
                                <option value="@DrinkTemperature.Other">Bánh / Khác</option>
                            </InputSelect>
                        </div>
                    </div>

                    <div class="row mb-4 align-items-end">
                        <div class="col-md-8">
                            <label class="form-label form-label-premium">Ảnh sản phẩm *</label>
                            <InputFile class="form-control form-control-premium" OnChange="HandleImageUpload" accept="image/png, image/jpeg, image/webp" />
                            @if (isUploadingImage)
                            {
                                <div class="mt-2 text-primary small fw-bold">
                                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Đang tải ảnh lên...
                                </div>
                            }
                            <ValidationMessage For="@(() => Model.ImageUrl)" class="text-danger small mt-1" />
                        </div>
                        <div class="col-md-4 text-center">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" width="90" height="90" class="rounded-3 object-fit-cover shadow-sm border" onerror="this.onerror=null; this.src='https://placehold.co/600x400?text=No+Image';" />
                            }
                            else
                            {
                                <div class="rounded-3 border bg-light d-flex align-items-center justify-content-center mx-auto shadow-sm" style="width: 90px; height: 90px;">
                                    <span class="small text-secondary fw-500">Chưa có ảnh</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mb-4 form-check form-switch px-4 py-3 bg-light rounded-3 border">
                        <InputCheckbox class="form-check-input ms-0 me-3 mt-1" style="transform: scale(1.3);" id="isActiveCheck" @bind-Value="Model.IsActive" />
                        <label class="form-check-label fw-bold text-dark" for="isActiveCheck">Trạng thái (Đang bán)</label>
                    </div>
                    
                    <div class="d-flex justify-content-end gap-3 mt-5">
                        <button type="button" class="btn btn-light px-4 rounded-3 fw-bold border" @onclick="OnClose">Hủy</button>
                        <button type="submit" class="btn btn-premium px-5" disabled="@IsSaving">
                            @if (IsSaving) { <span class="spinner-border spinner-border-sm me-2"></span><span>Đang lưu...</span> }
                            else { <span>Hoàn tất</span> }
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public SaveDrinkRequest Model { get; set; } = new();

    [Parameter]
    public int EditingDrinkId { get; set; } = 0;

    [Parameter]
    public List<CategoryDto> Categories { get; set; } = new();

    [Parameter]
    public bool IsSaving { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback<SaveDrinkRequest> OnSave { get; set; }

    private bool isUploadingImage = false;

    private async Task HandleValidSubmit()
    {
        await OnSave.InvokeAsync(Model);
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            try
            {
                isUploadingImage = true;
                StateHasChanged();

                var maxAllowedSize = 5 * 1024 * 1024; // 5MB
                using var stream = file.OpenReadStream(maxAllowedSize);
                
                var content = new MultipartFormDataContent();
                var fileContent = new StreamContent(stream);
                fileContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
                content.Add(fileContent, "file", file.Name);

                var imageUrl = await MenuApi.UploadImageAsync(content);
                
                if (!string.IsNullOrEmpty(imageUrl))
                {
                    Model.ImageUrl = imageUrl;
                }
                else
                {
                    await JSRuntime.InvokeVoidAsync("alert", "Không thể tải lên ảnh!");
                }
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Lỗi tải ảnh: {ex.Message}");
            }
            finally
            {
                isUploadingImage = false;
                StateHasChanged();
            }
        }
    }
}

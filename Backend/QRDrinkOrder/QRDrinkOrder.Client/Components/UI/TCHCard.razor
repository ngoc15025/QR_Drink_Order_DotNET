@namespace QRDrinkOrder.Client.Components.UI
@inject NavigationManager NavigationManager

<div class="tch-card @Class" @onclick="NavigateToUrl">
    @if (!string.IsNullOrEmpty(ImageUrl))
    {
        <img src="@ImageUrl" class="tch-card__image" alt="@Title" />
    }
    else if (!string.IsNullOrEmpty(Icon))
    {
        <div class="tch-card__icon-container">
            <svg class="tch-card__icon" viewBox="0 0 24 24" fill="currentColor">
                @((MarkupString)Icon)
            </svg>
        </div>
    }

    <div class="tch-card__content">
        <h3 class="tch-card__title">@Title</h3>
        @if (!string.IsNullOrEmpty(Description))
        {
            <p class="tch-card__description">@Description</p>
        }
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string ImageUrl { get; set; } = "";
    [Parameter] public string Icon { get; set; } = ""; // SVG Path or similar
    [Parameter] public string Url { get; set; } = "";
    [Parameter] public string Class { get; set; } = "";

    private void NavigateToUrl()
    {
        if (!string.IsNullOrEmpty(Url))
        {
            NavigationManager.NavigateTo(Url);
        }
    }
}

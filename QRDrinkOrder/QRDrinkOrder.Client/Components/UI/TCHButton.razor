@namespace QRDrinkOrder.Client.Components.UI

<button class="tch-button @(IsPrimary ? "tch-button--primary" : "tch-button--outline") @Class" @onclick="OnClickCallback" disabled="@Disabled" type="@Type">
    @if (!string.IsNullOrEmpty(Icon))
    {
        <span class="me-2">
            <i class="@Icon"></i>
        </span>
    }
    @Text
</button>

@code {
    [Parameter] public string Text { get; set; } = "Button";
    [Parameter] public bool IsPrimary { get; set; } = true;
    [Parameter] public string Class { get; set; } = "";
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public bool Disabled { get; set; } = false;
    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public EventCallback<Microsoft.AspNetCore.Components.Web.MouseEventArgs> OnClick { get; set; }

    private async Task OnClickCallback(Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        if (OnClick.HasDelegate)
        {
            await OnClick.InvokeAsync(e);
        }
    }
}

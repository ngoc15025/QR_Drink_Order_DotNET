@using QRDrinkOrder.Shared.DTOs.Responses
@using QRDrinkOrder.Shared.Enums

<div class="admin-table-card">
    <table class="admin-table">
        <thead>
            <tr>
                <th width="80">Ảnh</th>
                <th>Tên món</th>
                <th>Danh mục</th>
                <th>Giá bán</th>
                <th>Trạng thái</th>
                <th class="text-end">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var drink in Drinks)
            {
                <tr>
                    <td class="px-4 py-3">
                        <div class="drink-img-wrapper">
                            <img src="@drink.ImageUrl" onerror="this.onerror=null; this.src='https://placehold.co/600x400?text=No+Image';" />
                        </div>
                    </td>
                    <td class="py-3">
                        <div class="fw-bold text-dark" style="font-size: 0.95rem;">@drink.DrinkName</div>
                        <div class="mt-1">
                            @if(drink.TemperatureType == DrinkTemperature.Hot) { <span class="admin-badge" style="background-color: #ffe5e5; color: #dc3545;">Nóng</span> }
                            else if(drink.TemperatureType == DrinkTemperature.Iced) { <span class="admin-badge" style="background-color: #e5f4ff; color: #0d6efd;">Lạnh</span> }
                            else if(drink.TemperatureType == DrinkTemperature.Both) { <span class="admin-badge" style="background-color: #fff3cd; color: #ffc107;">Nóng/Lạnh</span> }
                            else { <span class="admin-badge badge-secondary">Khác</span> }
                        </div>
                    </td>
                    <td class="py-3 text-secondary small">
                        <span class="admin-badge badge-secondary">@(Categories.FirstOrDefault(c => c.CategoryId == drink.CategoryId)?.CategoryName ?? "Không rõ")</span>
                    </td>
                    <td class="py-3 fw-bold" style="color: var(--tch-orange, #ea8025);">@drink.BasePrice.ToString("N0")đ</td>
                    <td class="py-3">
                        @if (drink.IsActive)
                        {
                            <span class="admin-badge badge-success">Còn hàng</span>
                        }
                        else
                        {
                            <span class="admin-badge badge-danger">Hết hàng</span>
                        }
                    </td>
                    <td class="text-end">
                        <button class="btn-admin-action btn-action-secondary btn-action-sm" @onclick="() => OnEditDrink.InvokeAsync(drink)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16"><path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/><path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5v11z"/></svg>
                            Sửa
                        </button>
                        <button class="btn-admin-action btn-action-sm @(drink.IsActive ? "btn-action-danger" : "btn-action-success")" 
                                @onclick="() => OnToggleStatus.InvokeAsync(drink)">
                            @(drink.IsActive ? "Tắt" : "Bật")
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter]
    public List<DrinkDto> Drinks { get; set; } = new();

    [Parameter]
    public List<CategoryDto> Categories { get; set; } = new();

    [Parameter]
    public EventCallback<DrinkDto> OnEditDrink { get; set; }

    [Parameter]
    public EventCallback<DrinkDto> OnToggleStatus { get; set; }
}

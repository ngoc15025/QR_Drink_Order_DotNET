@using QRDrinkOrder.Shared.DTOs.Responses

<div class="table-responsive">
    <table class="table table-hover align-middle premium-table">
        <thead class="table-light">
            <tr>
                <th scope="col" style="width: 50px;">ID</th>
                <th scope="col">Tên Size</th>
                <th scope="col">Giá cộng thêm (VNĐ)</th>
                <th scope="col" class="text-center" style="width: 150px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Sizes == null || !Sizes.Any())
            {
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">Chưa có size nào.</td>
                </tr>
            }
            else
            {
                @foreach (var size in Sizes)
                {
                    <tr>
                        <td class="fw-bold text-secondary">#@size.SizeId</td>
                        <td class="fw-medium">@size.Name</td>
                        <td>
                            @if (size.PriceOffset == 0)
                            {
                                <span class="badge bg-light text-dark border">Mặc định (0 ₫)</span>
                            }
                            else
                            {
                                <span class="text-success fw-bold">+@size.PriceOffset.ToString("N0") ₫</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm" role="group">
                                <button class="btn btn-outline-primary" @onclick="() => OnEdit.InvokeAsync(size)" title="Chỉnh sửa">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-pencil" viewBox="0 0 16 16"><path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/></svg>
                                </button>
                                <button class="btn btn-outline-danger" @onclick="() => OnDelete.InvokeAsync(size.SizeId)" title="Xóa">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-trash" viewBox="0 0 16 16"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/><path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter] public List<SizeDto> Sizes { get; set; } = new();
    [Parameter] public EventCallback<SizeDto> OnEdit { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }
}

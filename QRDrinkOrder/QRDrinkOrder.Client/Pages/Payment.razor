@page "/payment/{OrderId:int}"
@inject QRDrinkOrder.Client.Services.OrderApiClient OrderApi
@inject QRDrinkOrder.Client.Services.BankAccountApiClient BankAccountApi
@using QRDrinkOrder.Shared.DTOs.Responses
@using QRDrinkOrder.Shared.Enums
@using Microsoft.AspNetCore.SignalR.Client
@inject Microsoft.AspNetCore.Components.NavigationManager NavigationManager
@inject Microsoft.JSInterop.IJSRuntime JS
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@inject ILogger<Payment> Logger
@implements IAsyncDisposable

<PageTitle>Thanh toán - Ngoc UwU Coffee</PageTitle>

<div class="mb-3 px-3 pt-3">
    <a href="/cart" class="text-decoration-none" style="color: var(--tch-text-main);">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-arrow-left me-2" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
        </svg>
        <span class="fw-bold">Thanh toán</span>
    </a>
</div>

<div class="px-3 pb-5">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <div class="mt-2 text-secondary small">Đang tải thông tin...</div>
        </div>
    }
    else if (order == null)
    {
        <div class="alert alert-danger">Không tìm thấy thông tin đơn hàng!</div>
    }
    else if (order.Payment?.PaymentStatus == (byte)PaymentStatus.Success)
    {
        <div class="text-center py-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="#22c55e" class="bi bi-check-circle mb-3" viewBox="0 0 16 16">
              <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
              <path d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05"/>
            </svg>
            <h5 class="fw-bold text-success mb-2">Thanh toán thành công!</h5>
            <p class="text-secondary small mb-4">Đang chuyển sang trang theo dõi đơn hàng...</p>
        </div>
    }
    else if (isExpired)
    {
        <div class="text-center py-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="#ef4444" class="bi bi-x-circle mb-3" viewBox="0 0 16 16">
              <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
              <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708"/>
            </svg>
            <h5 class="fw-bold text-danger mb-2">Hết thời gian thanh toán</h5>
            <p class="text-secondary small mb-4">Đơn hàng của bạn đã bị hủy do quá 15 phút chưa thanh toán.</p>
            <a href="/cart" class="btn btn-outline-primary fw-bold w-100">Quay lại Giỏ hàng</a>
        </div>
    }
    else
    {
        <div class="bg-white p-4 rounded shadow-sm text-center mb-4">
            <h5 class="fw-bold mb-3">Thanh toán qua VietQR</h5>
            
            <div class="mb-3 d-flex justify-content-center">
                @if (qrUrl != null)
                {
                    <div class="qr-container position-relative" style="max-width: 250px;">
                        <img src="@qrUrl" alt="QR Code" class="img-fluid border p-2 rounded" />
                        <div class="qr-overlay d-flex align-items-center justify-content-center" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; pointer-events: none;">
                            @if (isConnecting)
                            {
                                <div class="spinner-border text-primary" style="opacity: 0.8;" role="status"></div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="p-5 border rounded bg-light">
                        <span class="text-secondary small">Đang tạo mã QR...</span>
                    </div>
                }
            </div>
            
            <div class="d-flex justify-content-center gap-2 mb-4">
                <a href="@qrUrl" download="VietQR_Order_@(order.OrderId)" target="_blank" class="btn btn-sm btn-outline-secondary d-flex align-items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-download me-1" viewBox="0 0 16 16">
                        <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                        <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/>
                    </svg>
                    Lưu ảnh
                </a>
                <a href="https://dl.vietqr.io/pay?app=vietqr" target="_blank" class="btn btn-sm btn-outline-primary d-flex align-items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-phone me-1" viewBox="0 0 16 16">
                        <path d="M11 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h6zM5 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H5z"/>
                        <path d="M8 14a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/>
                    </svg>
                    Mở App Ngân hàng
                </a>
            </div>
            
            <div class="bg-light p-3 rounded mb-4 text-start">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-secondary small">Ngân hàng:</span>
                    <strong class="text-dark">@bankName</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-secondary small">Chủ TK:</span>
                    <strong class="text-dark">@accountName</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-secondary small">Số tài khoản:</span>
                    <strong class="text-dark fs-6">@accountNumber</strong>
                </div>
                <hr style="border-top: 1px dashed var(--tch-border);" />
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-secondary small">Số tiền:</span>
                    <strong class="text-primary fs-5">@order.TotalAmount.ToString("N0") đ</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-secondary small">Nội dung CK:</span>
                    <strong class="text-success fs-6">UwU@(order.OrderId)</strong>
                </div>
            </div>

            
            <div class="text-danger fw-bold mb-4">
                Thời gian còn lại: @timeRemainingStr
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary flex-grow-1 fw-bold py-2" @onclick="ChangePaymentMethod" disabled="@isChangingPayment">
                    @if (isChangingPayment)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Thay đổi phương thức thanh toán
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int OrderId { get; set; }

    private bool isLoading = true;
    private OrderDto? order;
    private string? qrUrl;
    
    private string bankName = "...";
    private string accountNumber = "...";
    private string accountName = "...";

    private HubConnection? hubConnection;
    private bool isConnecting = true;
    
    // Timer
    private System.Timers.Timer? _timer;
    private int _remainingSeconds = 15 * 60; // 15 mins
    private string timeRemainingStr = "15:00";
    private bool isExpired = false;
    private bool isChangingPayment = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            order = await OrderApi.GetOrderByIdAsync(OrderId);
            
            if (order != null)
            {
                // Nếu đã thanh toán, không cần hiện QR nữa
                if (order.Payment?.PaymentStatus == (byte)PaymentStatus.Success)
                {
                    _ = RedirectToTrack();
                    return;
                }
                
                // Fetch bank account
                var banks = await BankAccountApi.GetBankAccountsAsync();
                var activeBank = banks.FirstOrDefault(b => b.IsActive);
                
                if (activeBank != null)
                {
                    bankName = activeBank.BankCode;
                    accountNumber = activeBank.AccountNumber;
                    accountName = activeBank.AccountName;
                    
                    qrUrl = $"https://img.vietqr.io/image/{activeBank.BankCode}-{activeBank.AccountNumber}-compact.png?amount={order.TotalAmount}&addInfo=UwU{order.OrderId}&accountName={Uri.EscapeDataString(activeBank.AccountName)}";
                }
                
                StartTimer();
                
                // SignalR Connection
                await ConnectSignalR();
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartTimer()
    {
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += async (sender, e) =>
        {
            _remainingSeconds--;
            if (_remainingSeconds <= 0)
            {
                _timer.Stop();
                isExpired = true;
                
                // Tự động hủy đơn khi hết giờ
                try {
                    if (order != null) {
                        await OrderApi.CancelOrderAsync(order.OrderId, order.SessionId);
                    }
                } catch (Exception ex) { 
                    Logger.LogError(ex, "Failed to auto-cancel order {OrderId}", order?.OrderId);
                }
                
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                var min = _remainingSeconds / 60;
                var sec = _remainingSeconds % 60;
                timeRemainingStr = $"{min:D2}:{sec:D2}";
                await InvokeAsync(StateHasChanged);
            }
        };
        _timer.Start();
    }

    private async Task ConnectSignalR()
    {
        var backendUrl = Config["BackendApiUrl"] ?? "http://localhost:5153";
        
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl($"{backendUrl.TrimEnd('/')}/orderhub") // Gọi tới cổng của API server
                .WithAutomaticReconnect()
                .Build();

            hubConnection.On<StatusUpdateMessage>("ReceiveStatusUpdate", async (payload) =>
            {
                if (payload.OrderId == OrderId)
                {
                    if (payload.PaymentStatus == (byte)PaymentStatus.Success || payload.StatusName == "Đã thanh toán")
                    {
                        if (order != null && order.Payment != null)
                        {
                            order.Payment.PaymentStatus = (byte)PaymentStatus.Success;
                        }
                        await InvokeAsync(StateHasChanged);
                        await RedirectToTrack();
                    }
                }
            });

            await hubConnection.StartAsync();
            if (order != null)
            {
                await hubConnection.InvokeAsync("JoinCustomerGroup", order.SessionId.ToString());
            }
            isConnecting = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Lỗi kết nối SignalR");
            isConnecting = false;
            await InvokeAsync(StateHasChanged);
        }
    }
    
    private async Task ChangePaymentMethod()
    {
        if (order == null) return;
        
        isChangingPayment = true;
        try 
        {
            // Update phương thức thanh toán sang Tiền mặt
            var success = await OrderApi.UpdatePaymentMethodAsync(order.OrderId, order.SessionId, (byte)PaymentMethod.Cash);
            if (success)
            {
                NavigationManager.NavigateTo($"/track-order/{OrderId}");
            }
            else
            {
                isChangingPayment = false;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Lỗi khi thay đổi phương thức thanh toán");
            isChangingPayment = false;
        }
    }

    private async Task RedirectToTrack()
    {
        // Chờ 2s để khách thấy thông báo
        await Task.Delay(2000);
        NavigationManager.NavigateTo($"/track-order/{OrderId}");
    }

    public async ValueTask DisposeAsync()
    {
        if (_timer != null)
        {
            _timer.Stop();
            _timer.Dispose();
        }
        
        if (hubConnection is not null)
        {
            try
            {
                if (order != null)
                {
                    await hubConnection.InvokeAsync("LeaveCustomerGroup", order.SessionId.ToString());
                }
                await hubConnection.DisposeAsync();
            }
            catch (Exception ex) 
            { 
                Logger.LogWarning(ex, "Lỗi khi Dispose HubConnection");
            }
        }
    }

    private class StatusUpdateMessage
    {
        public int OrderId { get; set; }
        public byte Status { get; set; }
        public string StatusName { get; set; } = "";
        public byte? PaymentStatus { get; set; }
    }
}

@page "/menu"
@implements IDisposable
@inject QRDrinkOrder.Client.Services.MenuApiClient MenuApi
@inject QRDrinkOrder.Client.Services.Interfaces.IAiRecommendationApiClient AiApi
@inject QRDrinkOrder.Client.Services.CartState CartState
@using QRDrinkOrder.Shared.DTOs.Responses
@using QRDrinkOrder.Client.Services
@inject Microsoft.JSInterop.IJSRuntime JSRuntime
@inject ILogger<Menu> Logger

<PageTitle>Thực đơn - Ngoc UwU Coffee</PageTitle>

@if (isLoading)
{
    <div class="menu-layout">
        <!-- Sidebar Skeleton -->
        <div class="menu-sidebar" style="position: sticky; top: 70px; height: calc(100vh - 70px); background: transparent; border-right: none;">
            @for (int i = 0; i < 6; i++)
            {
                <div class="skeleton-box" style="width: 50px; height: 50px; border-radius: 12px; margin: 0 auto 20px; display: block;"></div>
            }
        </div>
        <!-- Content Skeleton -->
        <div class="menu-content px-3 pt-3">
            <!-- Search skeleton -->
            <div class="skeleton-box skeleton-search"></div>
            <!-- AI button skeleton -->
            <div class="skeleton-box" style="width: 100%; height: 50px; border-radius: 12px; margin-bottom: 24px;"></div>
            
            <div class="skeleton-box skeleton-text-title" style="margin-bottom: 20px;"></div>
            @for (int i = 0; i < 5; i++)
            {
                <div class="skeleton-card skeleton-card-horizontal" style="padding: 12px;">
                    <div class="skeleton-box" style="width: 70px; height: 70px; border-radius: 12px; flex-shrink: 0;"></div>
                    <div class="d-flex flex-column justify-content-center w-100 ps-2">
                        <div class="skeleton-box skeleton-text" style="width: 80%;"></div>
                        <div class="skeleton-box skeleton-text-sm" style="width: 40%;"></div>
                        <div class="skeleton-box skeleton-text-sm" style="width: 30%; margin-top: 12px;"></div>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="menu-layout">
        <!-- Sidebar Danh mục (Left) -->
        <div class="menu-sidebar" style="position: sticky; top: 70px; height: calc(100vh - 70px);" id="sidebar-container">
            <div class="sidebar-item @(selectedCategoryId == null ? "active" : "")" id="sidebar-cat-all" @onclick="() => SelectCategory(null)">
                @if (selectedCategoryId == null)
                {
                    <div class="sidebar-img-wrapper">
                        <img src="/images/logo.png" class="sidebar-img" onerror="this.onerror=null; this.src='/images/placeholder.png';" />
                    </div>
                }
                <div class="sidebar-text">Tất cả</div>
            </div>
            @foreach (var cat in categories)
            {
                var catImg = GetCategoryImageUrl(cat.CategoryId);
                var isActive = selectedCategoryId == cat.CategoryId;
                <div class="sidebar-item @(isActive ? "active" : "")" id="sidebar-cat-@cat.CategoryId"
                     @onclick="() => SelectCategory(cat.CategoryId)">
                    @if (isActive)
                    {
                        <div class="sidebar-img-wrapper">
                            <img src="@catImg" class="sidebar-img" onerror="this.onerror=null; this.src='/images/placeholder.png';" />
                        </div>
                    }
                    <div class="sidebar-text">@cat.CategoryName</div>
                </div>
            }
            <!-- Spacer để scroll không bị che bởi bottom nav -->
            <div style="height: 80px; flex-shrink: 0;"></div>
        </div>

        <!-- Danh sách món (Right) -->
        <div class="menu-content" id="menu-content-scroll">
            <div class="mb-3 d-flex align-items-center px-3 pt-3 pb-2 bg-white sticky-top" style="z-index: 10;">
                <div class="input-group">
                    <span class="input-group-text bg-light border-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search text-secondary" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/></svg>
                    </span>
                    <input type="text" class="form-control bg-light border-0" placeholder="Tìm kiếm món..." @bind="searchQuery" @bind:event="oninput" />
                </div>
            </div>

            <div class="px-3 pb-3">
                <button class="btn w-100 fw-bold d-flex align-items-center justify-content-center gap-2" style="background-color: #FFF3E0; color: var(--tch-orange); border: 1px solid rgba(234, 128, 37, 0.5); border-radius: 12px; padding: 12px;" @onclick="GetAiSuggestions" disabled="@isAiLoading">
                    @if (isAiLoading)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        <span>Đang phân tích thời tiết...</span>
                    }
                    else
                    {
                        <span style="font-size: 1.2rem;">🤖</span>
                        <span>Bạn ơi, hãy gợi ý cho tôi</span>
                    }
                </button>

                @if (smartSuggestion != null && aiDrinks.Any())
                {
                    <div class="mt-3 p-3 rounded-4 glass-panel" style="background: rgba(250, 140, 22, 0.1); border: 1px solid rgba(250, 140, 22, 0.2);">
                        <div class="d-flex mb-2">
                            <span class="fs-4 me-2">✨</span>
                            <p class="mb-0 fw-medium" style="color: #d86900; font-size: 0.95rem; line-height: 1.5;">@smartSuggestion.RecommendationText</p>
                        </div>
                        <div class="d-flex overflow-auto pb-2 gap-2" style="scroll-snap-type: x mandatory;">
                            @foreach (var drink in aiDrinks)
                            {
                                <div class="card border-0 rounded-4 shadow-sm" style="min-width: 140px; scroll-snap-align: start;" @onclick="() => OpenDrinkModal(drink)">
                                    <img src="@(string.IsNullOrEmpty(drink.ImageUrl) ? "/images/placeholder.png" : drink.ImageUrl)" class="card-img-top rounded-top-4 object-fit-cover" style="height: 100px;" alt="@drink.DrinkName" onerror="this.onerror=null; this.src='/images/placeholder.png';">
                                    <div class="card-body p-2 text-center">
                                        <div class="fw-bold small text-truncate">@drink.DrinkName</div>
                                        <div class="text-orange fw-bold small">@drink.BasePrice.ToString("N0")đ</div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="px-3">
                @if (FilteredCategories.Any())
                {
                    @foreach (var group in FilteredCategories)
                    {
                        var drinksInGroup = FilteredDrinks.Where(d => d.CategoryId == group.CategoryId).ToList();
                        if (drinksInGroup.Any())
                        {
                            <div class="category-header sticky-top" id="cat-@group.CategoryId">
                                @group.CategoryName
                            </div>

                            <div class="drink-list">
                                @foreach (var drink in drinksInGroup)
                                {
                                    <div class="drink-item-card" @onclick="() => OpenDrinkModal(drink)">
                                        <div class="drink-item-img">
                                            <img src="@(string.IsNullOrEmpty(drink.ImageUrl) ? "/images/placeholder.png" : drink.ImageUrl)" alt="@drink.DrinkName" class="w-100 h-100 object-fit-cover" loading="lazy" onerror="this.onerror=null; this.src='/images/placeholder.png';">
                                            @if (!drink.IsActive)
                                            {
                                                <div class="out-of-stock-overlay">
                                                    <span class="badge bg-secondary">Hết</span>
                                                </div>
                                            }
                                        </div>
                                        <div class="drink-item-info">
                                            <div class="drink-item-name">@drink.DrinkName</div>
                                            <div class="drink-item-price">@drink.BasePrice.ToString("N0")đ</div>
                                        </div>
                                        <div class="drink-item-action">
                                            @if (drink.IsActive)
                                            {
                                                <button class="btn-add-plus">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                                        <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                                                    </svg>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                }
                else
                {
                    <div class="text-center py-5 text-secondary">
                        Không tìm thấy món nào!
                    </div>
                }
                <div style="height: 100px;"></div>
            </div>
        </div>
    </div>

    <div class="drawer-overlay @(isModalOpen ? "open" : "")" @onclick="CloseModal"></div>
    <div class="customization-drawer glass-panel @(isModalOpen ? "open" : "")">
        @if (selectedDrink != null)
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0">Thêm món mới</h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            
            <div class="d-flex mb-4 align-items-center">
                <img src="@(string.IsNullOrEmpty(selectedDrink.ImageUrl) ? "/images/placeholder.png" : selectedDrink.ImageUrl)" 
                     class="rounded" style="width: 70px; height: 70px; object-fit: cover;" alt="@selectedDrink.DrinkName" onerror="this.onerror=null; this.src='/images/placeholder.png';">
                <div class="ms-3">
                    <h6 class="fw-bold mb-1" style="font-size: 1.1rem;">@selectedDrink.DrinkName</h6>
                    <div class="fw-bold" style="font-size: 1.1rem; color: var(--tch-orange);">@selectedDrink.BasePrice.ToString("N0")đ</div>
                </div>
            </div>

            <hr style="border-top: 1px solid var(--tch-border);" />

            @if (!string.IsNullOrEmpty(selectedDrink.Description))
            {
                <div class="text-secondary mb-4" style="font-size: 0.9rem; line-height: 1.5;">@selectedDrink.Description</div>
            }

            <div class="mb-4">
                <label class="form-label fw-bold small text-secondary" style="letter-spacing: 0.05em;">ĐỘ NGỌT</label>
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn @(sweetness == 0 ? "btn-outline-primary active" : "btn-outline-secondary") flex-fill fw-bold rounded-pill" @onclick="() => sweetness = 0">0%</button>
                    <button class="btn @(sweetness == 30 ? "btn-outline-primary active" : "btn-outline-secondary") flex-fill fw-bold rounded-pill" @onclick="() => sweetness = 30">30%</button>
                    <button class="btn @(sweetness == 50 ? "btn-outline-primary active" : "btn-outline-secondary") flex-fill fw-bold rounded-pill" @onclick="() => sweetness = 50">50%</button>
                    <button class="btn @(sweetness == 70 ? "btn-outline-primary active" : "btn-outline-secondary") flex-fill fw-bold rounded-pill" @onclick="() => sweetness = 70">70%</button>
                    <button class="btn @(sweetness == 100 ? "btn-outline-primary active" : "btn-outline-secondary") flex-fill fw-bold rounded-pill" @onclick="() => sweetness = 100">100%</button>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold small text-secondary" style="letter-spacing: 0.05em;">LƯỢNG ĐÁ</label>
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn @(ice == 0 ? "btn-outline-primary active" : "btn-outline-secondary") flex-fill fw-bold rounded-pill" @onclick="() => ice = 0">0%</button>
                    <button class="btn @(ice == 50 ? "btn-outline-primary active" : "btn-outline-secondary") flex-fill fw-bold rounded-pill" @onclick="() => ice = 50">50%</button>
                    <button class="btn @(ice == 100 ? "btn-outline-primary active" : "btn-outline-secondary") flex-fill fw-bold rounded-pill" @onclick="() => ice = 100">100%</button>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold small text-uppercase text-secondary mb-3">Chọn Size</label>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var size in sizes)
                    {
                        <button type="button" 
                                class="btn btn-outline-primary size-btn @(selectedSize?.SizeId == size.SizeId ? "active" : "")" 
                                @onclick="() => SelectSize(size)">
                            <span class="d-block fw-bold">@size.Name</span>
                            <span class="d-block small">@(size.PriceOffset > 0 ? $"+{size.PriceOffset.ToString("N0")}đ" : "Miễn phí")</span>
                        </button>
                    }
                </div>
            </div>

            @if (toppings.Any())
            {
                <div class="mb-4">
                    <label class="form-label fw-bold small text-secondary" style="letter-spacing: 0.05em;">TOPPING</label>
                    <div class="d-flex flex-column gap-2">
                        @foreach (var topping in toppings)
                        {
                            <div class="form-check d-flex align-items-center bg-light rounded px-3 py-2 border @(selectedToppings.Any(t => t.ToppingId == topping.ToppingId) ? "border-primary" : "border-0")" 
                                 @onclick="() => ToggleTopping(topping)" style="cursor: pointer;">
                                <input class="form-check-input mt-0 me-2" type="checkbox" checked="@(selectedToppings.Any(t => t.ToppingId == topping.ToppingId))" />
                                <label class="form-check-label flex-grow-1 fw-medium" style="pointer-events: none;">@topping.Name</label>
                                <span class="text-orange fw-bold">+@topping.Price.ToString("N0")đ</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="mb-4">
                <label class="form-label fw-bold small text-secondary" style="letter-spacing: 0.05em;">YÊU CẦU KHÁC</label>
                <input type="text" class="form-control bg-light border-0 py-2 rounded-pill px-3" placeholder="Ghi chú thêm cho quán..." @bind="note" />
            </div>

            <div class="d-flex align-items-center mt-3 pt-3" style="border-top: 1px solid var(--tch-border);">
                <div class="d-flex align-items-center me-3 bg-light rounded-pill px-2 py-1">
                    <button class="btn btn-sm border-0 fs-5 text-orange rounded-circle" style="color: var(--tch-orange); width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;" @onclick="DecreaseQuantity">-</button>
                    <span class="px-3 fw-bold fs-5">@quantity</span>
                    <button class="btn btn-sm border-0 fs-5 text-orange rounded-circle" style="color: var(--tch-orange); width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;" @onclick="IncreaseQuantity">+</button>
                </div>
                <button class="btn btn-primary flex-grow-1 py-3 fw-bold fs-6" style="border-radius: 24px;" @onclick="AddToCart">
                    Thêm - @((GetUnitPrice() * quantity).ToString("N0"))đ
                </button>
            </div>
        }
    </div>
}


@code {
    private string GetCategoryImageUrl(int? categoryId)
    {
        if (categoryId == null)
        {
            return "/images/logo.png";
        }
        var firstDrink = allDrinks.FirstOrDefault(d => d.CategoryId == categoryId);
        return string.IsNullOrEmpty(firstDrink?.ImageUrl) ? "/images/placeholder.png" : firstDrink.ImageUrl;
    }

    private bool isLoading = true;
    private List<CategoryDto> categories = new();
    private List<DrinkDto> allDrinks = new();
    private List<SizeDto> sizes = new();
    private List<ToppingDto> toppings = new();
    private int? selectedCategoryId = null;
    private string searchQuery = "";

    private bool isAiLoading = false;
    private AiRecommendationResultDto? smartSuggestion;
    private List<DrinkDto> aiDrinks = new();

    private bool isModalOpen = false;
    private DrinkDto? selectedDrink;
    private byte sweetness = 100;
    private byte ice = 100;
    private int quantity = 1;
    private string note = "";
    private SizeDto? selectedSize;
    private List<ToppingDto> selectedToppings = new();

    private decimal GetUnitPrice()
    {
        if (selectedDrink == null) return 0;
        decimal basePrice = selectedDrink.BasePrice;
        decimal sizeOffset = selectedSize?.PriceOffset ?? 0;
        decimal toppingTotal = selectedToppings.Sum(t => t.Price);
        return basePrice + sizeOffset + toppingTotal;
    }

    private void ToggleTopping(ToppingDto topping)
    {
        var existing = selectedToppings.FirstOrDefault(t => t.ToppingId == topping.ToppingId);
        if (existing != null)
            selectedToppings.Remove(existing);
        else
            selectedToppings.Add(topping);
    }

    private void SelectSize(SizeDto size) => selectedSize = size;

    private IEnumerable<CategoryDto> FilteredCategories
    {
        get
        {
            var cats = categories.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var matchingCategoryIds = allDrinks
                    .Where(d => d.DrinkName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
                    .Select(d => d.CategoryId)
                    .Distinct();
                cats = cats.Where(c => matchingCategoryIds.Contains(c.CategoryId));
            }
            return cats;
        }
    }

    private IEnumerable<DrinkDto> FilteredDrinks 
    {
        get
        {
            var query = allDrinks.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                query = query.Where(d => d.DrinkName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
            }
            return query;
        }
    }

    private DotNetObjectReference<Menu>? objRef;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    [JSInvokable]
    public void UpdateActiveCategory(int? id)
    {
        if (selectedCategoryId != id)
        {
            selectedCategoryId = id;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        objRef?.Dispose();
        try { _ = JSRuntime.InvokeVoidAsync("menuScrollSpy.dispose"); } 
        catch (Exception ex) { Logger.LogWarning(ex, "Lỗi khi dispose scrollSpy"); }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            categories = await MenuApi.GetCategoriesAsync();
            allDrinks = await MenuApi.GetDrinksAsync();
            sizes = await MenuApi.GetSizesAsync();
            toppings = await MenuApi.GetToppingsAsync();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
            await Task.Delay(150);
            try {
                objRef = DotNetObjectReference.Create(this);
                await JSRuntime.InvokeVoidAsync("menuScrollSpy.initialize", objRef);
            } catch (Exception ex) { Logger.LogWarning(ex, "Lỗi khi initialize scrollSpy"); }
            try {
                await JSRuntime.InvokeVoidAsync("gsapHelpers.staggerLoad", ".drink-item-card");
            } catch (Exception ex) { Logger.LogWarning(ex, "Lỗi khi gọi gsapHelpers.staggerLoad"); }
        }
    }

    private async Task SelectCategory(int? id)
    {
        selectedCategoryId = id;
        searchQuery = "";
        if (id.HasValue)
        {
            await JSRuntime.InvokeVoidAsync("menuScrollSpy.scrollToCategory", id.Value);
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("menuScrollSpy.scrollToTop");
        }
    }

    private void OpenDrinkModal(DrinkDto drink)
    {
        if (!drink.IsActive) return; 
        
        selectedDrink = drink;
        sweetness = 100;
        ice = 100;
        quantity = 1;
        note = "";
        selectedSize = sizes.FirstOrDefault();
        selectedToppings.Clear();
        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
    }

    private void IncreaseQuantity() => quantity++;
    private void DecreaseQuantity()
    {
        if (quantity > 1) quantity--;
    }

    private async Task AddToCart(Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        if (selectedDrink != null)
        {
            CartState.AddToCart(selectedDrink, quantity, sweetness, ice, note, selectedSize, selectedToppings);
            try {
                await JSRuntime.InvokeVoidAsync("animateAddToCart", selectedDrink.ImageUrl, e.ClientX, e.ClientY);
            } catch (Exception ex) { Logger.LogWarning(ex, "Lỗi khi gọi animateAddToCart"); }
            CloseModal();
        }
    }

    private async Task GetAiSuggestions()
    {
        try
        {
            isAiLoading = true;
            smartSuggestion = await AiApi.GetLatestRecommendationAsync();
            if (smartSuggestion != null)
            {
                if (smartSuggestion.DrinkIds != null && smartSuggestion.DrinkIds.Any())
                {
                    aiDrinks = allDrinks.Where(d => smartSuggestion.DrinkIds.Contains(d.DrinkId)).ToList();
                    smartSuggestion.RecommendationText = smartSuggestion.Message; // Populate text for UI to display
                }
                else if (!string.IsNullOrEmpty(smartSuggestion.RecommendationText))
                {
                    var drinkNames = smartSuggestion.RecommendationText.Split(',');
                    aiDrinks = allDrinks.Where(d => drinkNames.Any(name => d.DrinkName.Contains(name.Trim(), StringComparison.OrdinalIgnoreCase))).ToList();
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error getting AI suggestions");
        }
        finally
        {
            isAiLoading = false;
            StateHasChanged();
        }
    }
}


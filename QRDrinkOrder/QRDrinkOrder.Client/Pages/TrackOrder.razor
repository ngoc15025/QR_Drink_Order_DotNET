@page "/track-order/{OrderId:int}"
@inject QRDrinkOrder.Client.Services.OrderApiClient OrderApi
@inject QRDrinkOrder.Client.Services.ReviewApiClient ReviewApi
@using QRDrinkOrder.Shared.DTOs.Responses
@using QRDrinkOrder.Shared.DTOs.Requests
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Components.Forms
@inject Microsoft.AspNetCore.Components.NavigationManager NavigationManager
@implements IAsyncDisposable

<PageTitle>Theo dõi Đơn hàng - Ngoc UwU Coffee</PageTitle>

<div class="mb-3 px-3 pt-3">
    <a href="/order" class="text-decoration-none" style="color: var(--tch-text-main);">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-arrow-left me-2" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
        </svg>
        <span class="fw-bold">Chi tiết Đơn hàng #@OrderId</span>
    </a>
</div>

<div class="px-3 pb-5">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <div class="mt-2 text-secondary small">Đang lấy thông tin...</div>
        </div>
    }
    else if (order == null)
    {
        <div class="alert alert-danger">Không tìm thấy thông tin đơn hàng!</div>
    }
    else
    {
        <!-- Tracking Timeline -->
        <div class="tch-card p-4 mb-4">
            <h6 class="fw-bold mb-4 text-center">Trạng thái đơn hàng</h6>
            <div class="d-flex justify-content-between position-relative">
                <div class="progress position-absolute" style="height: 3px; top: 15px; left: 10%; right: 10%; z-index: 0;">
                    <div class="progress-bar bg-success" role="progressbar" style="width: @(GetProgressWidth())%;" aria-valuenow="@GetProgressWidth()" aria-valuemin="0" aria-valuemax="100"></div>
                </div>

                <div class="text-center" style="z-index: 1;">
                    <div class="rounded-circle text-white d-flex align-items-center justify-content-center mx-auto mb-2 @(order.OrderStatus >= 0 ? "bg-success" : "bg-secondary")" style="width: 32px; height: 32px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-receipt" viewBox="0 0 16 16"><path d="M1.92.506a.5.5 0 0 1 .434.14L3 1.293l.646-.647a.5.5 0 0 1 .708 0L5 1.293l.646-.647a.5.5 0 0 1 .708 0L7 1.293l.646-.647a.5.5 0 0 1 .708 0L9 1.293l.646-.647a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .801.13l.5 1A.5.5 0 0 1 15 2v12a.5.5 0 0 1-.053.224l-.5 1a.5.5 0 0 1-.8.13L13 14.707l-.646.647a.5.5 0 0 1-.708 0L11 14.707l-.646.647a.5.5 0 0 1-.708 0L9 14.707l-.646.647a.5.5 0 0 1-.708 0L7 14.707l-.646.647a.5.5 0 0 1-.708 0L5 14.707l-.646.647a.5.5 0 0 1-.708 0L3 14.707l-.646.647a.5.5 0 0 1-.801-.13l-.5-1A.5.5 0 0 1 1 14V2a.5.5 0 0 1 .053-.224l.5-1a.5.5 0 0 1 .367-.27zm.217 1.338L2 2.118v11.764l.137.274.51-.51a.5.5 0 0 1 .707 0l.646.647.646-.646a.5.5 0 0 1 .708 0l.646.646.646-.646a.5.5 0 0 1 .708 0l.646.646.646-.646a.5.5 0 0 1 .708 0l.646.646.646-.646a.5.5 0 0 1 .708 0l.646.646.646-.646a.5.5 0 0 1 .708 0l.509.509.137-.274V2.118l-.137-.274-.51.51a.5.5 0 0 1-.707 0L12 1.707l-.646.647a.5.5 0 0 1-.708 0L10 1.707l-.646.647a.5.5 0 0 1-.708 0L8 1.707l-.646.647a.5.5 0 0 1-.708 0L6 1.707l-.646.647a.5.5 0 0 1-.708 0L4 1.707l-.646.647a.5.5 0 0 1-.708 0l-.509-.51zM3 4.5a.5.5 0 0 1 .5-.5h6a.5.5 0 1 1 0 1h-6a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h6a.5.5 0 1 1 0 1h-6a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h6a.5.5 0 1 1 0 1h-6a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5zm8-6a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1-.5-.5z"/></svg>
                    </div>
                    <div class="small fw-bold @(order.OrderStatus >= 0 ? "text-success" : "text-secondary")">Đã nhận</div>
                </div>

                <div class="text-center" style="z-index: 1;">
                    <div class="rounded-circle text-white d-flex align-items-center justify-content-center mx-auto mb-2 @(order.OrderStatus >= 1 ? "bg-success" : "bg-secondary")" style="width: 32px; height: 32px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-cup-hot" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M.5 6a.5.5 0 0 0-.488.608l1.652 7.434A2.5 2.5 0 0 0 4.104 16h5.792a2.5 2.5 0 0 0 2.44-1.958l.131-.59a3 3 0 0 0 1.3-5.854l.221-1.006A.5.5 0 0 0 13.5 6H.5ZM13 12.5a2.01 2.01 0 0 1-.316-.025l.867-3.928A2 2 0 0 1 13 12.5Z"/><path d="M2.14 7h9.22l-1.14 5.144a1.5 1.5 0 0 1-1.464 1.176H4.744a1.5 1.5 0 0 1-1.464-1.176L2.14 7Z"/></svg>
                    </div>
                    <div class="small fw-bold @(order.OrderStatus >= 1 ? "text-success" : "text-secondary")">Pha chế</div>
                </div>

                <div class="text-center" style="z-index: 1;">
                    <div class="rounded-circle text-white d-flex align-items-center justify-content-center mx-auto mb-2 @(order.OrderStatus >= 2 ? "bg-success" : "bg-secondary")" style="width: 32px; height: 32px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-lg" viewBox="0 0 16 16"><path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425a.247.247 0 0 1 .02-.022Z"/></svg>
                    </div>
                    <div class="small fw-bold @(order.OrderStatus >= 2 ? "text-success" : "text-secondary")">Hoàn thành</div>
                </div>
            </div>

            @if (order.OrderStatus == 3)
            {
                <div class="mt-4 text-center text-danger fw-bold">
                    Đơn hàng này đã bị hủy.
                </div>
            }
        </div>

        <div class="tch-card p-3 mb-4">
            <h6 class="fw-bold mb-3 border-bottom pb-2">Thông tin nhận hàng</h6>
            <div class="d-flex mb-2">
                <div class="text-secondary small" style="width: 100px;">Thời gian:</div>
                <div class="fw-bold">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
            <div class="d-flex mb-2">
                <div class="text-secondary small" style="width: 100px;">Hình thức:</div>
                <div class="fw-bold">@(string.IsNullOrEmpty(order.TableNumber) || order.TableNumber == "Quầy" ? "Nhận tại quầy" : $"Tại bàn ({order.TableNumber})")</div>
            </div>
            <div class="d-flex mb-2">
                <div class="text-secondary small" style="width: 100px;">Trạng thái:</div>
                <div>
                    @if (order.Payment != null && order.Payment.PaymentStatus == 1)
                    {
                        <span class="badge bg-success">Đã thanh toán</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Chưa thanh toán</span>
                    }
                </div>
            </div>
        </div>

        <!-- Order Items -->
        <div class="tch-card p-3 mb-4">
            <h6 class="fw-bold mb-3 border-bottom pb-2">Danh sách món</h6>
            @foreach (var item in order.Items)
            {
                <div class="d-flex justify-content-between mb-3 align-items-center">
                    <div class="d-flex">
                        <div class="fw-bold text-primary me-2">@item.Quantity x</div>
                        <div>
                            <div class="fw-bold">@item.DrinkName</div>
                            <div class="small text-secondary">Đá: @item.IceLevel%, Đường: @item.SweetnessLevel%</div>
                            @if (!string.IsNullOrEmpty(item.ItemNote))
                            {
                                <div class="small text-secondary">Ghi chú: @item.ItemNote</div>
                            }
                        </div>
                    </div>
                    <div class="fw-bold">@((item.UnitPrice * item.Quantity).ToString("N0"))đ</div>
                </div>
            }

            <hr style="border-top: 1px dashed var(--tch-border);" />
            <div class="d-flex justify-content-between pt-2">
                <span class="fw-bold">Tổng cộng:</span>
                <span class="fw-bold text-orange fs-5" style="color: var(--tch-orange);">@order.TotalAmount.ToString("N0")đ</span>
            </div>
        </div>

        <!-- Khung đánh giá đơn hàng -->
        @if (order.OrderStatus == 2)
        {
            <div class="tch-card p-3 mb-4">
                <h6 class="fw-bold mb-3 border-bottom pb-2" style="color: var(--tch-text-main);">Đánh giá đơn hàng</h6>
                @if (order.IsReviewed)
                {
                    <div class="alert alert-success mb-0 py-2 small text-center d-flex align-items-center justify-content-center" style="border-radius: 8px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill me-2" viewBox="0 0 16 16">
                          <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                        </svg>
                        Bạn đã gửi đánh giá cho đơn hàng này. Cảm ơn bạn!
                    </div>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(reviewError))
                    {
                        <div class="alert alert-danger py-2 small" style="border-radius: 8px;">@reviewError</div>
                    }
                    @if (reviewSuccess)
                    {
                        <div class="alert alert-success py-2 small" style="border-radius: 8px;">Gửi đánh giá thành công. Cảm ơn ý kiến của bạn!</div>
                    }
                    else
                    {
                        <div class="mb-3 text-center">
                            <label class="d-block text-secondary small mb-2">Mức độ hài lòng của bạn</label>
                            <div class="d-flex justify-content-center gap-2">
                                @for (byte i = 1; i <= 5; i++)
                                {
                                    byte starValue = i;
                                    <span style="cursor: pointer; font-size: 28px; color: @(reviewRating >= starValue ? "#FFB100" : "#E2E8F0"); transition: color 0.15s ease;"
                                          @onclick="() => reviewRating = starValue">
                                        ★
                                    </span>
                                }
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-secondary">Lời nhận xét</label>
                            <textarea class="form-control" rows="3" placeholder="Chia sẻ trải nghiệm của bạn về nước uống và dịch vụ..." @bind="reviewComment" style="border-radius: 8px; font-size: 14px; border: 1px solid #e2e8f0;"></textarea>
                        </div>
                        
                        <!-- Hiển thị danh sách ảnh xem trước -->
                        @if (reviewImagesBase64.Any())
                        {
                            <div class="d-flex gap-2 mb-3 flex-wrap">
                                @foreach (var img in reviewImagesBase64)
                                {
                                    <div class="position-relative animate__animated animate__fadeIn" style="width: 60px; height: 60px;">
                                        <img src="@img" class="w-100 h-100 rounded object-fit-cover shadow-sm" />
                                        <button type="button" class="btn btn-danger btn-sm rounded-circle position-absolute d-flex align-items-center justify-content-center" 
                                                style="width: 18px; height: 18px; top: -5px; right: -5px; padding: 0; font-size: 12px; line-height: 1;"
                                                @onclick="() => reviewImagesBase64.Remove(img)">
                                            ×
                                        </button>
                                    </div>
                                }
                            </div>
                        }

                        <div class="d-flex justify-content-between align-items-center">
                            <InputFile OnChange="HandleFileSelected" multiple accept="image/*" class="d-none" id="file-upload" />
                            <label for="file-upload" class="btn btn-outline-secondary btn-sm d-flex align-items-center" style="border-radius: 20px; font-weight: 500; padding: 6px 12px; border-color: #cbd5e1; color: #475569; cursor: pointer;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-camera me-1" viewBox="0 0 16 16">
                                    <path d="M15 12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h1.172a3 3 0 0 0 2.12-.879l.83-.828A1 1 0 0 1 6.827 3h2.344a1 1 0 0 1 .707.293l.828.828A3 3 0 0 0 12.828 5H14a1 1 0 0 1 1 1v6zM2 4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-1.172a2 2 0 0 1-1.414-.586l-.828-.828A2 2 0 0 0 9.172 2H6.828a2 2 0 0 0-1.414.586l-.828.828A2 2 0 0 1 3.172 4H2z"/>
                                    <path d="M8 11a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5zm0 1a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7zM3 6.5a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0z"/>
                                </svg>
                                Thêm ảnh
                            </label>

                            <button class="btn btn-primary btn-sm px-4 fw-bold" style="border-radius: 20px; background-color: var(--tch-orange); border-color: var(--tch-orange);" 
                                    @onclick="SubmitReview" disabled="@isSubmittingReview">
                                @if (isSubmittingReview)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                Gửi đánh giá
                            </button>
                        </div>
                    }
                }
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public int OrderId { get; set; }

    private bool isLoading = true;
    private OrderDto? order;
    private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrder();

        // Kết nối SignalR để nhận cập nhật trạng thái realtime
        var baseUrl = NavigationManager.BaseUri.Replace(NavigationManager.Uri.Replace(NavigationManager.BaseUri, ""), ""); // Lấy host của client. Trong thực tế sẽ trỏ tới API Host.
        var apiBaseUrl = "http://localhost:5153"; // Hardcode API host cho dev

        hubConnection = new HubConnectionBuilder()
            .WithUrl($"{apiBaseUrl}/orderhub")
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<StatusUpdateMessage>("ReceiveStatusUpdate", (payload) =>
        {
            if (order != null && payload.OrderId == OrderId)
            {
                order.OrderStatus = payload.Status;
                if (payload.PaymentStatus.HasValue && order.Payment != null)
                {
                    order.Payment.PaymentStatus = payload.PaymentStatus.Value;
                }
                StateHasChanged();
            }
        });

        try
        {
            await hubConnection.StartAsync();
            if (order != null)
            {
                await hubConnection.SendAsync("JoinCustomerSessionGroup", order.SessionId.ToString());
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SignalR Connection Error: {ex.Message}");
        }
    }

    private async Task LoadOrder()
    {
        try
        {
            isLoading = true;
            order = await OrderApi.GetOrderByIdAsync(OrderId);
        }
        finally
        {
            isLoading = false;
        }
    }

    private int GetProgressWidth()
    {
        if (order == null) return 0;
        if (order.OrderStatus == 3) return 0; // Đã hủy
        if (order.OrderStatus == 0) return 0;
        if (order.OrderStatus == 1) return 50;
        if (order.OrderStatus == 2) return 100;
        return 0;
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    private byte reviewRating = 5;
    private string reviewComment = "";
    private List<string> reviewImagesBase64 = new();
    private bool isSubmittingReview = false;
    private bool reviewSuccess = false;
    private string reviewError = "";

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        reviewError = "";
        try
        {
            var files = e.GetMultipleFiles(3); // Tối đa 3 ảnh
            foreach (var file in files)
            {
                if (file.ContentType.StartsWith("image/"))
                {
                    var resizedImage = await file.RequestImageFileAsync(file.ContentType, 600, 600);
                    using var stream = resizedImage.OpenReadStream(2 * 1024 * 1024);
                    using var ms = new System.IO.MemoryStream();
                    await stream.CopyToAsync(ms);
                    var base64 = $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
                    reviewImagesBase64.Add(base64);
                }
            }
        }
        catch (Exception ex)
        {
            reviewError = "Lỗi khi xử lý ảnh: " + ex.Message;
        }
    }

    private async Task SubmitReview()
    {
        if (order == null) return;
        isSubmittingReview = true;
        reviewError = "";
        reviewSuccess = false;
        try
        {
            var req = new SubmitReviewRequest
            {
                OrderId = OrderId,
                Rating = reviewRating,
                Comment = reviewComment,
                Base64Images = reviewImagesBase64
            };
            var success = await ReviewApi.SubmitReviewAsync(order.SessionId, req);
            if (success)
            {
                reviewSuccess = true;
                order.IsReviewed = true;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            reviewError = ex.Message;
        }
        finally
        {
            isSubmittingReview = false;
        }
    }

    private class StatusUpdateMessage
    {
        public int OrderId { get; set; }
        public byte Status { get; set; }
        public string? StatusName { get; set; }
        public byte? PaymentStatus { get; set; }
    }
}


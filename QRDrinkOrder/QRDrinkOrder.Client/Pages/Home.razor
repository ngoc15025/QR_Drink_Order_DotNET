@page "/"
@implements IDisposable
@inject Microsoft.JSInterop.IJSRuntime JSRuntime
@inject QRDrinkOrder.Client.Services.MenuApiClient MenuApi
@inject QRDrinkOrder.Client.Services.CartState CartState
@using QRDrinkOrder.Shared.DTOs.Responses
@using QRDrinkOrder.Client.Services
@using QRDrinkOrder.Client.Components.UI
@inject ILogger<Home> Logger

<PageTitle>Trang chủ - Ngoc UwU Coffee</PageTitle>

@if (isLoading)
{
    <div class="home-container" style="display: flex; flex-direction: column; height: calc(100vh - 60px); max-height: calc(100vh - 60px); overflow: hidden;">
        <div class="home-scroll-area no-scrollbar" style="overflow-y: hidden; flex: 1; background-color: #FFFFFF; padding: 16px;">
            <!-- Promo skeleton -->
            <div class="skeleton-box" style="width: 100%; height: 160px; border-radius: 12px; margin-bottom: 24px;"></div>
            
            <!-- Search skeleton -->
            <div class="skeleton-box skeleton-search"></div>
            
            <div class="d-flex position-relative">
                <!-- Sidebar skeleton -->
                <div class="menu-sidebar" style="width: 80px; padding-top: 0; border-right: none; background: transparent;">
                    @for (int i = 0; i < 6; i++)
                    {
                        <div class="skeleton-box" style="width: 50px; height: 50px; border-radius: 12px; margin: 0 auto 20px; display: block;"></div>
                    }
                </div>
                <!-- Drink list skeleton -->
                <div class="flex-grow-1" style="min-width: 0; padding-left: 12px;">
                    <div class="skeleton-box skeleton-text-title" style="margin-bottom: 20px;"></div>
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="skeleton-card skeleton-card-horizontal" style="padding: 12px;">
                            <div class="skeleton-box" style="width: 70px; height: 70px; border-radius: 12px; flex-shrink: 0;"></div>
                            <div class="d-flex flex-column justify-content-center w-100 ps-2">
                                <div class="skeleton-box skeleton-text" style="width: 90%;"></div>
                                <div class="skeleton-box skeleton-text-sm" style="width: 50%;"></div>
                                <div class="skeleton-box skeleton-text-sm" style="width: 30%; margin-top: 12px;"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="home-container" style="display: flex; flex-direction: column; height: calc(100vh - 60px); max-height: calc(100vh - 60px); overflow: hidden;">
        <!-- Nội dung chính có thể cuộn toàn bộ -->
        <div class="home-scroll-area no-scrollbar" id="menu-content-scroll" style="overflow-y: auto; flex: 1; background-color: #FFFFFF;">
            
            <!-- TIN TỨC (Promotions) -->
            @if (promotions.Any())
            {
                <h4 class="fw-bold px-3 pt-3 mb-2" style="color: #000033; font-size: 1.2rem;">TIN TỨC</h4>
                <div class="promo-carousel-wrapper mx-3" id="promoCarouselWrapper" style="border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.05); background-color: #fef8e5;">
                    <!-- Slides -->
                    <div class="promo-slides" id="promoSlides">
                        @for (int i = 0; i < promotions.Count; i++)
                        {
                            var promo = promotions[i];
                            var idx = i;
                            <div class="promo-slide" @onclick="() => OpenPromoModal(idx)">
                                <img src="@promo.ImageUrl" alt="@promo.Title"
                                     onerror="this.onerror=null; this.src='/images/placeholder.png';" />
                                
                                <div class="promo-slide-footer">
                                    <div class="promo-slide-meta">
                                        <span class="promo-slide-category">COFFEEHOLIC</span>
                                        <span class="promo-slide-date">@(promo.StartDate?.ToString("dd/MM/yyyy") ?? DateTime.Now.ToString("dd/MM/yyyy"))</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(promo.Title))
                                    {
                                        <h5 class="promo-slide-title">@promo.Title</h5>
                                    }
                                    @if (!string.IsNullOrEmpty(promo.Description))
                                    {
                                        <p class="promo-slide-desc">@promo.Description</p>
                                    }
                                    @if (!string.IsNullOrEmpty(promo.CouponCode))
                                    {
                                        <div class="mt-2">
                                            <span class="badge bg-success">Mã: @promo.CouponCode</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    <!-- Dots navigation -->
                    @if (promotions.Count > 1)
                    {
                        <div class="promo-dots">
                            @for (int i = 0; i < promotions.Count; i++)
                            {
                                var idx = i;
                                <span class="promo-dot @(currentPromoIndex == idx ? "active" : "")" @onclick="() => GoToSlide(idx)"></span>
                            }
                        </div>
                    }
                </div>
            }

            <!-- Modal chi tiết khuyến mãi -->
            @if (isPromoModalOpen && selectedPromo != null)
            {
                <div class="promo-detail-backdrop" @onclick="ClosePromoModal">
                    <div class="promo-detail-modal" @onclick:stopPropagation>
                        <button class="promo-detail-close" @onclick="ClosePromoModal">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"><path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/></svg>
                        </button>
                        <img src="@selectedPromo.ImageUrl" alt="@selectedPromo.Title" class="promo-detail-img"
                             onerror="this.onerror=null; this.src='/images/placeholder.png';" />
                        <div class="promo-detail-body">
                            @if (!string.IsNullOrEmpty(selectedPromo.Title))
                            {
                                <h2 class="promo-detail-title">@selectedPromo.Title</h2>
                            }
                            @if (!string.IsNullOrEmpty(selectedPromo.Description))
                            {
                                <p class="promo-detail-desc">@selectedPromo.Description</p>
                            }
                            @if (selectedPromo.StartDate.HasValue || selectedPromo.EndDate.HasValue)
                            {
                                <div class="promo-detail-dates">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z"/></svg>
                                    <span>
                                        @if (selectedPromo.StartDate.HasValue)
                                        { <text>Từ @selectedPromo.StartDate.Value.ToString("dd/MM/yyyy")</text> }
                                        @if (selectedPromo.EndDate.HasValue)
                                        { <text> đến @selectedPromo.EndDate.Value.ToString("dd/MM/yyyy")</text> }
                                    </span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(selectedPromo.CouponCode))
                            {
                                <div class="promo-detail-coupon">
                                    <div class="promo-detail-coupon-info">
                                        <span class="promo-detail-coupon-label">Mã khuyến mãi</span>
                                        <strong class="promo-detail-coupon-code">@selectedPromo.CouponCode</strong>
                                        @if (selectedPromo.DiscountValue.HasValue)
                                        {
                                            <span class="promo-detail-discount">
                                                @if (selectedPromo.DiscountType == 1)
                                                { <text>Giảm @selectedPromo.DiscountValue.Value.ToString("N0")đ</text> }
                                                else
                                                { <text>Giảm @selectedPromo.DiscountValue.Value%</text> }
                                            </span>
                                        }
                                    </div>
                                    <button class="promo-detail-copy-btn" @onclick="() => CopyPromoCode(selectedPromo.CouponCode)">
                                        @if (copiedCode == selectedPromo.CouponCode)
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425a.247.247 0 0 1 .02-.022Z"/></svg>
                                            <text>Đã copy!</text>
                                        }
                                        else
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M4 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2zm2-1a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1zM2 5a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-1h1v1a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h1v1z"/></svg>
                                            <text>Sao chép mã</text>
                                        }
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Thanh tìm kiếm (Sticky) -->
            <div class="px-3 pt-3 pb-3 bg-white sticky-top" style="z-index: 10;">
                <div class="input-group" style="border: 1px solid #e0e0e0; border-radius: 24px; overflow: hidden; background: #fff;">
                    <span class="input-group-text bg-white border-0 ps-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-search text-secondary" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/></svg>
                    </span>
                    <input type="text" class="form-control border-0 py-2 shadow-none" placeholder="Tìm món" @bind="searchQuery" @bind:event="oninput" style="font-size: 15px;" />
                </div>
            </div>

            <!-- Vùng Menu 2 cột: Sidebar và List -->
            <div class="d-flex align-items-start position-relative" style="background-color: #FFFFFF;">
                <!-- Sidebar -->
                <div class="menu-sidebar" style="position: sticky; top: 70px; max-height: calc(100vh - 130px); height: auto; border-right: none;" id="sidebar-container">
                    <div class="sidebar-item @(selectedCategoryId == null ? "active" : "")" id="sidebar-cat-all" @onclick="() => SelectCategory(null)">
                        @if (selectedCategoryId == null)
                        {
                            <div class="sidebar-img-wrapper">
                                <img src="/images/logo.png" class="sidebar-img" onerror="this.onerror=null; this.src='/images/placeholder.png';" />
                            </div>
                        }
                        <div class="sidebar-text">Tất cả</div>
                    </div>
                    @foreach (var cat in categories)
                    {
                        var catImg = GetCategoryImageUrl(cat.CategoryId);
                        var isActive = selectedCategoryId == cat.CategoryId;
                        <div class="sidebar-item @(isActive ? "active" : "")" id="sidebar-cat-@cat.CategoryId"
                             @onclick="() => SelectCategory(cat.CategoryId)">
                            @if (isActive)
                            {
                                <div class="sidebar-img-wrapper">
                                    <img src="@catImg" class="sidebar-img" onerror="this.onerror=null; this.src='/images/placeholder.png';" />
                                </div>
                            }
                            <div class="sidebar-text">@cat.CategoryName</div>
                        </div>
                    }
                    <!-- Spacer để scroll không bị che bởi bottom nav -->
                    <div style="height: 80px; flex-shrink: 0;"></div>
                </div>

                <!-- Danh sách món -->
                <div class="flex-grow-1 px-3 pt-3" style="min-width: 0;">
                @if (FilteredCategories.Any())
                {
                    @foreach (var group in FilteredCategories)
                    {
                        var drinksInGroup = FilteredDrinks.Where(d => d.CategoryId == group.CategoryId).ToList();
                        if (drinksInGroup.Any())
                        {
                            <!-- Category Header -->
                            <div class="category-header sticky-top" style="top: 72px;" id="cat-@group.CategoryId">
                                @group.CategoryName
                            </div>

                            <!-- Món ăn ngang -->
                            <div class="drink-list">
                                @foreach (var drink in drinksInGroup)
                                {
                                    <div class="drink-item-card" @onclick="() => OpenDrinkModal(drink)">
                                        <div class="drink-item-img">
                                            <img src="@(string.IsNullOrEmpty(drink.ImageUrl) ? "/images/placeholder.png" : drink.ImageUrl)" alt="@drink.DrinkName" class="w-100 h-100 object-fit-cover" loading="lazy" onerror="this.onerror=null; this.src='/images/placeholder.png';">
                                            @if (!drink.IsActive)
                                            {
                                                <div class="out-of-stock-overlay">
                                                    <span class="badge bg-secondary">Hết</span>
                                                </div>
                                            }
                                        </div>
                                        <div class="drink-item-info">
                                            <div class="drink-item-name">@drink.DrinkName</div>
                                            <div class="drink-item-price">@drink.BasePrice.ToString("N0")đ</div>
                                        </div>
                                        <div class="drink-item-action">
                                            @if (drink.IsActive)
                                            {
                                                <button class="btn-add-plus">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                                        <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                                                    </svg>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                }
                else
                {
                    <div class="text-center py-5 text-secondary">
                        Không tìm thấy món nào!
                    </div>
                }
                <!-- Spacer để thẻ cuối cùng không bị che bởi bottom nav -->
                <div style="height: 100px;"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="drawer-overlay @(isModalOpen ? "open" : "")" @onclick="CloseModal"></div>
    <div class="customization-drawer glass-panel @(isModalOpen ? "open" : "")">
        @if (selectedDrink != null)
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <button type="button" class="btn btn-link text-dark p-0 border-0 d-flex align-items-center justify-content-start" style="width: 24px;" @onclick="CloseOrBackModal">
                    @if (modalStack.Count > 0)
                    {
                        <i class="bi bi-arrow-left fs-5" style="color: var(--tch-orange);"></i>
                    }
                    else
                    {
                        <i class="bi bi-x-lg fs-5"></i>
                    }
                </button>
                <h6 class="fw-bold mb-0 mx-auto">Thêm vào giỏ</h6>
                <div style="width: 24px;"></div>
            </div>
            
            <div class="@modalAnimClass" @key="selectedDrink?.DrinkId">
                @if (modalStack.Count > 0)
                {
                    var parentDrink = modalStack.Peek().Drink;
                    <div class="tch-back-banner mb-3 d-flex align-items-center justify-content-between p-2 rounded" @onclick="CloseOrBackModal" style="cursor: pointer;">
                        <div class="d-flex align-items-center text-dark overflow-hidden me-2">
                            <i class="bi bi-arrow-left-circle-fill fs-5 me-2" style="color: var(--tch-orange);"></i>
                            <div class="text-truncate">
                                <span class="small text-muted d-block" style="font-size: 0.75rem;">Đang chọn kèm cho món chính:</span>
                                <strong class="text-dark text-truncate d-block" style="font-size: 0.85rem;">@parentDrink.DrinkName</strong>
                            </div>
                        </div>
                        <span class="badge rounded-pill px-2 py-1 small flex-shrink-0" style="background-color: var(--tch-orange); color: white;">Quay lại <i class="bi bi-arrow-return-left"></i></span>
                    </div>
                }

                <div class="d-flex mb-4 align-items-center">
                    <img src="@(string.IsNullOrEmpty(selectedDrink.ImageUrl) ? "/images/placeholder.png" : selectedDrink.ImageUrl)" 
                         class="rounded" style="width: 70px; height: 70px; object-fit: cover;" alt="@selectedDrink.DrinkName" onerror="this.onerror=null; this.src='/images/placeholder.png';">
                    <div class="ms-3">
                        <h6 class="fw-bold mb-1" style="font-size: 1.1rem;">@selectedDrink.DrinkName</h6>
                        <div class="fw-bold" style="font-size: 1.1rem; color: var(--tch-orange);">@selectedDrink.BasePrice.ToString("N0")đ</div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(selectedDrink.Description))
                {
                    <div class="text-secondary mb-3" style="font-size: 0.9rem; line-height: 1.5;">@selectedDrink.Description</div>
                }

                @if (suggestedPairings.Any())
                {
                    <div class="pairing-section mb-3">
                        <div class="text-secondary small fw-bold mb-2" style="letter-spacing: 0.05em;">GỢI Ý DÙNG KÈM</div>
                        <div class="d-flex gap-2 overflow-auto no-scrollbar pb-1">
                            @foreach (var item in suggestedPairings)
                            {
                                <div class="pairing-card" @onclick="() => OpenPairingModal(item)">
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/placeholder.png" : item.ImageUrl)" 
                                         class="rounded-circle me-2" style="width: 44px; height: 44px; object-fit: cover;" 
                                         alt="@item.DrinkName" onerror="this.onerror=null; this.src='/images/placeholder.png';" />
                                    <div class="flex-grow-1 overflow-hidden me-1">
                                        <div class="fw-bold text-truncate" style="font-size: 0.85rem; color: var(--tch-text-main);">@item.DrinkName</div>
                                        <div class="text-orange fw-bold" style="font-size: 0.8rem;">@item.BasePrice.ToString("N0")đ</div>
                                    </div>
                                    <button type="button" class="btn-pairing-add" @onclick:stopPropagation="true" @onclick="() => OpenPairingModal(item)">Thêm &gt;</button>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="tch-section-bar">Chọn 1 Loại Size</div>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    @foreach (var size in sizes)
                    {
                        <button type="button" 
                                class="tch-opt-btn @(selectedSize?.SizeId == size.SizeId ? "active" : "")" 
                                @onclick="() => SelectSize(size)">
                            <span class="d-block">@size.Name @(size.PriceOffset > 0 ? $"({size.PriceOffset.ToString("N0")}đ)" : "")</span>
                        </button>
                    }
                </div>

                <div class="tch-section-bar">Lượng Đá</div>
                <div class="d-flex gap-2 flex-wrap mb-3">
                    <button type="button" class="tch-opt-btn @(ice == 0 ? "active" : "")" @onclick="() => ice = 0">0%</button>
                    <button type="button" class="tch-opt-btn @(ice == 50 ? "active" : "")" @onclick="() => ice = 50">50%</button>
                    <button type="button" class="tch-opt-btn @(ice == 100 ? "active" : "")" @onclick="() => ice = 100">100%</button>
                </div>

                <div class="tch-section-bar">Độ Ngọt</div>
                <div class="d-flex gap-2 flex-wrap mb-3">
                    <button type="button" class="tch-opt-btn @(sweetness == 0 ? "active" : "")" @onclick="() => sweetness = 0">0%</button>
                    <button type="button" class="tch-opt-btn @(sweetness == 30 ? "active" : "")" @onclick="() => sweetness = 30">30%</button>
                    <button type="button" class="tch-opt-btn @(sweetness == 50 ? "active" : "")" @onclick="() => sweetness = 50">50%</button>
                    <button type="button" class="tch-opt-btn @(sweetness == 70 ? "active" : "")" @onclick="() => sweetness = 70">70%</button>
                    <button type="button" class="tch-opt-btn @(sweetness == 100 ? "active" : "")" @onclick="() => sweetness = 100">100%</button>
                </div>

                @if (toppings.Any())
                {
                    <div class="tch-section-bar">Topping</div>
                    <div class="d-flex flex-column gap-2 mb-3">
                        @foreach (var topping in toppings)
                        {
                            <div class="form-check d-flex align-items-center bg-light rounded px-3 py-2 border @(selectedToppings.Any(t => t.ToppingId == topping.ToppingId) ? "border-primary" : "border-0")" 
                                 @onclick="() => ToggleTopping(topping)" style="cursor: pointer;">
                                <input class="form-check-input mt-0 me-2" type="checkbox" checked="@(selectedToppings.Any(t => t.ToppingId == topping.ToppingId))" />
                                <label class="form-check-label flex-grow-1 fw-medium" style="pointer-events: none;">@topping.Name</label>
                                <span class="text-orange fw-bold">+@topping.Price.ToString("N0")đ</span>
                            </div>
                        }
                    </div>
                }

                <div class="tch-section-bar">Yêu Cầu Khác</div>
                <div class="mb-4">
                    <input type="text" class="form-control bg-light border-0 py-2 rounded-pill px-3" placeholder="Ghi chú thêm cho quán..." @bind="note" />
                </div>
            </div>

            <div class="d-flex align-items-center mt-3 pt-3" style="border-top: 1px solid var(--tch-border);">
                <div class="d-flex align-items-center me-3 bg-light rounded-pill px-2 py-1">
                    <button type="button" class="btn btn-sm border-0 fs-5 text-orange rounded-circle" style="color: var(--tch-orange); width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;" @onclick="DecreaseQuantity">-</button>
                    <span class="px-3 fw-bold fs-5">@quantity</span>
                    <button type="button" class="btn btn-sm border-0 fs-5 text-orange rounded-circle" style="color: var(--tch-orange); width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;" @onclick="IncreaseQuantity">-</button>
                </div>
                <button type="button" class="btn btn-primary flex-grow-1 py-3 fw-bold fs-6" style="border-radius: 24px;" @onclick="AddToCart">
                    Thêm - @((GetUnitPrice() * quantity).ToString("N0"))đ
                </button>
            </div>
        }
    </div>
}


@code {
    private bool isLoading = true;
    private List<CategoryDto> categories = new();
    private List<DrinkDto> allDrinks = new();
    private List<PromotionDto> promotions = new();
    private int? selectedCategoryId = null;
    private string searchQuery = "";

    // Trạng thái cho Drawer
    private bool isModalOpen = false;
    private DrinkDto? selectedDrink;
    private List<DrinkDto> suggestedPairings = new();
    private byte sweetness = 100;
    private byte ice = 100;
    private int quantity = 1;
    private string note = "";
    private class DrinkModalState
    {
        public DrinkDto Drink { get; set; } = default!;
        public byte Sweetness { get; set; }
        public byte Ice { get; set; }
        public int Quantity { get; set; }
        public string Note { get; set; } = "";
        public SizeDto? SelectedSize { get; set; }
        public List<ToppingDto> SelectedToppings { get; set; } = new();
        public List<DrinkDto> SuggestedPairings { get; set; } = new();
    }
    private Stack<DrinkModalState> modalStack = new();
    private string modalAnimClass = "";

    private List<SizeDto> sizes = new();
    private List<ToppingDto> toppings = new();
    private SizeDto? selectedSize;
    private List<ToppingDto> selectedToppings = new();

    private decimal GetUnitPrice()
    {
        if (selectedDrink == null) return 0;
        decimal basePrice = selectedDrink.BasePrice;
        decimal sizeOffset = selectedSize?.PriceOffset ?? 0;
        decimal toppingTotal = selectedToppings.Sum(t => t.Price);
        return basePrice + sizeOffset + toppingTotal;
    }

    private void ToggleTopping(ToppingDto topping)
    {
        var existing = selectedToppings.FirstOrDefault(t => t.ToppingId == topping.ToppingId);
        if (existing != null)
            selectedToppings.Remove(existing);
        else
            selectedToppings.Add(topping);
    }

    private void SelectSize(SizeDto size) => selectedSize = size;

    // Trạng thái cho Promotion Carousel
    private int currentPromoIndex = 0;
    private bool isPromoModalOpen = false;
    private PromotionDto? selectedPromo;
    private System.Threading.CancellationTokenSource? _promoTimerCts;

    private string GetCategoryImageUrl(int categoryId)
    {
        var firstDrink = allDrinks.FirstOrDefault(d => d.CategoryId == categoryId);
        if (firstDrink != null && !string.IsNullOrEmpty(firstDrink.ImageUrl))
        {
            return firstDrink.ImageUrl;
        }
        return "/images/placeholder.png";
    }

    private IEnumerable<CategoryDto> FilteredCategories
    {
        get
        {
            var cats = categories.AsEnumerable();
            // Không lọc theo selectedCategoryId để ScrollSpy hoạt động
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                var matchingCategoryIds = allDrinks
                    .Where(d => d.DrinkName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
                    .Select(d => d.CategoryId)
                    .Distinct();
                cats = cats.Where(c => matchingCategoryIds.Contains(c.CategoryId));
            }
            return cats;
        }
    }

    private IEnumerable<DrinkDto> FilteredDrinks 
    {
        get
        {
            var query = allDrinks.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                query = query.Where(d => d.DrinkName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
            }
            return query;
        }
    }

    private DotNetObjectReference<Home>? objRef;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            StartAutoSlide();
        }
    }

    [JSInvokable]
    public void UpdateActiveCategory(int? id)
    {
        if (selectedCategoryId != id)
        {
            selectedCategoryId = id;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void UpdatePromoIndex(int idx)
    {
        if (currentPromoIndex != idx)
        {
            currentPromoIndex = idx;
            StateHasChanged();
            
            // Đặt lại timer khi user vuốt tay (lướt ngang)
            StartAutoSlide();
        }
    }

    public void Dispose()
    {
        _promoTimerCts?.Cancel();
        _promoTimerCts?.Dispose();
        objRef?.Dispose();
        try { _ = JSRuntime.InvokeVoidAsync("menuScrollSpy.dispose"); } 
        catch (Exception ex) { Logger.LogWarning(ex, "Lỗi khi dispose scrollSpy"); }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            categories = await MenuApi.GetCategoriesAsync();
            allDrinks = await MenuApi.GetDrinksAsync();
            promotions = await MenuApi.GetPromotionsAsync();
            sizes = await MenuApi.GetSizesAsync();
            toppings = await MenuApi.GetToppingsAsync();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
            await Task.Delay(150);
            try {
                objRef = DotNetObjectReference.Create(this);
                await JSRuntime.InvokeVoidAsync("menuScrollSpy.initialize", objRef);
                await JSRuntime.InvokeVoidAsync("promoCarousel.init", objRef);
            } catch (Exception ex) { Logger.LogWarning(ex, "Lỗi khi initialize scrollSpy / promoCarousel"); }
            try {
                await JSRuntime.InvokeVoidAsync("gsapHelpers.staggerLoad", ".drink-item-card");
            } catch (Exception ex) { Logger.LogWarning(ex, "Lỗi khi gọi gsapHelpers.staggerLoad"); }
        }
    }

    private async Task SelectCategory(int? id)
    {
        selectedCategoryId = id;
        searchQuery = "";
        if (id.HasValue)
        {
            await JSRuntime.InvokeVoidAsync("menuScrollSpy.scrollToCategory", id.Value);
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("menuScrollSpy.scrollToTop");
        }
    }

    private void OpenDrinkModal(DrinkDto drink, bool isFromPairing = false)
    {
        if (!drink.IsActive) return;
        
        if (!isFromPairing)
        {
            modalStack.Clear();
            modalAnimClass = "";
        }

        selectedDrink = drink;
        // Reset options
        sweetness = 100;
        ice = 100;
        quantity = 1;
        note = "";
        selectedSize = sizes.FirstOrDefault();
        selectedToppings.Clear();
        UpdateSmartPairings(drink);
        isModalOpen = true;
    }

    private void OpenPairingModal(DrinkDto pairingItem)
    {
        if (selectedDrink != null)
        {
            modalStack.Push(new DrinkModalState
            {
                Drink = selectedDrink,
                Sweetness = sweetness,
                Ice = ice,
                Quantity = quantity,
                Note = note,
                SelectedSize = selectedSize,
                SelectedToppings = new List<ToppingDto>(selectedToppings),
                SuggestedPairings = new List<DrinkDto>(suggestedPairings)
            });
        }
        modalAnimClass = "anim-stack-push";
        OpenDrinkModal(pairingItem, true);
    }

    private void CloseOrBackModal()
    {
        if (modalStack.Count > 0)
        {
            var parent = modalStack.Pop();
            selectedDrink = parent.Drink;
            sweetness = parent.Sweetness;
            ice = parent.Ice;
            quantity = parent.Quantity;
            note = parent.Note;
            selectedSize = parent.SelectedSize;
            selectedToppings = parent.SelectedToppings;
            suggestedPairings = parent.SuggestedPairings;
            modalAnimClass = "anim-stack-pop";
        }
        else
        {
            CloseModal();
        }
    }

    private void UpdateSmartPairings(DrinkDto currentDrink)
    {
        if (allDrinks == null || currentDrink == null)
        {
            suggestedPairings.Clear();
            return;
        }

        bool isFoodOrOther = currentDrink.TemperatureType == QRDrinkOrder.Shared.Enums.DrinkTemperature.Other;

        if (!isFoodOrOther)
        {
            var pairings = allDrinks
                .Where(d => d.TemperatureType == QRDrinkOrder.Shared.Enums.DrinkTemperature.Other && d.DrinkId != currentDrink.DrinkId && d.IsActive)
                .OrderBy(x => Guid.NewGuid())
                .Take(3)
                .ToList();

            if (!pairings.Any())
            {
                pairings = allDrinks
                    .Where(d => d.CategoryId != currentDrink.CategoryId && d.DrinkId != currentDrink.DrinkId && d.IsActive)
                    .OrderBy(x => Guid.NewGuid())
                    .Take(3)
                    .ToList();
            }
            suggestedPairings = pairings;
        }
        else
        {
            suggestedPairings = allDrinks
                .Where(d => d.TemperatureType != QRDrinkOrder.Shared.Enums.DrinkTemperature.Other && d.DrinkId != currentDrink.DrinkId && d.IsActive)
                .OrderBy(x => Guid.NewGuid())
                .Take(3)
                .ToList();
        }
    }

    private void CloseModal()
    {
        isModalOpen = false;
        modalStack.Clear();
    }

    private void IncreaseQuantity() => quantity++;
    private void DecreaseQuantity()
    {
        if (quantity > 1) quantity--;
    }

    private async Task AddToCart(Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        if (selectedDrink != null)
        {
            CartState.AddToCart(selectedDrink, quantity, sweetness, ice, note, selectedSize, selectedToppings);
            try {
                await JSRuntime.InvokeVoidAsync("animateAddToCart", selectedDrink.ImageUrl, e.ClientX, e.ClientY);
            } catch (Exception ex) { Logger.LogWarning(ex, "Lỗi khi gọi animateAddToCart"); }
            
            if (modalStack.Count > 0)
            {
                var parent = modalStack.Pop();
                selectedDrink = parent.Drink;
                sweetness = parent.Sweetness;
                ice = parent.Ice;
                quantity = parent.Quantity;
                note = parent.Note;
                selectedSize = parent.SelectedSize;
                selectedToppings = parent.SelectedToppings;
                suggestedPairings = parent.SuggestedPairings;
                modalAnimClass = "anim-stack-pop";
            }
            else
            {
                CloseModal();
            }
        }
    }

    private string copiedCode = "";
    private async Task CopyPromoCode(string code)
    {
        if (string.IsNullOrEmpty(code)) return;
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", code);
            copiedCode = code;
            StateHasChanged();
            await Task.Delay(2000);
            if (copiedCode == code)
            {
                copiedCode = "";
                StateHasChanged();
            }
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Lỗi khi copy mã khuyến mãi"); }
    }

    private void GoToSlide(int idx)
    {
        currentPromoIndex = idx;
        var slidePercent = idx * 100;
        JSRuntime.InvokeVoidAsync("promoCarousel.goTo", slidePercent);
    }

    private void OpenPromoModal(int idx)
    {
        selectedPromo = promotions[idx];
        isPromoModalOpen = true;
    }

    private void ClosePromoModal()
    {
        isPromoModalOpen = false;
        selectedPromo = null;
    }

    private void StartAutoSlide()
    {
        if (promotions.Count <= 1) return;
        _promoTimerCts?.Cancel();
        _promoTimerCts = new System.Threading.CancellationTokenSource();
        var token = _promoTimerCts.Token;
        _ = Task.Run(async () =>
        {
            while (!token.IsCancellationRequested)
            {
                await Task.Delay(4000, token);
                if (token.IsCancellationRequested) break;
                await InvokeAsync(() =>
                {
                    currentPromoIndex = (currentPromoIndex + 1) % promotions.Count;
                    var slidePercent = currentPromoIndex * 100;
                    JSRuntime.InvokeVoidAsync("promoCarousel.goTo", slidePercent);
                    StateHasChanged();
                });
            }
        }, token);
    }

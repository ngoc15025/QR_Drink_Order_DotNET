@page "/pos"
@attribute [Authorize(Roles = "Employee")]
@inject NavigationManager NavigationManager
@inject QRDrinkOrder.Client.Services.OrderApiClient OrderApi
@inject QRDrinkOrder.Client.Services.SystemConfigApiClient ConfigApi
@inject IJSRuntime JSRuntime
@using QRDrinkOrder.Shared.DTOs.Responses
@using Microsoft.AspNetCore.SignalR.Client
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@inject ILogger<EmployeeDashboard> Logger
@inject QRDrinkOrder.Client.Services.LocalStorageService LocalStorage
@implements IAsyncDisposable

<PageTitle>POS - Ngoc UwU Coffee</PageTitle>

<div class="pos-wrapper">
    <!-- POS Header -->
    <header class="pos-header">
        <div class="pos-header-left">
            <div class="pos-logo-mark">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M18 8h1a4 4 0 0 1 0 8h-1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <line x1="6" y1="1" x2="6" y2="4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <line x1="10" y1="1" x2="10" y2="4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <line x1="14" y1="1" x2="14" y2="4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>
            <div>
                <h1 class="pos-title">Màn hình POS</h1>
                <p class="pos-subtitle">Ngoc UwU Coffee · Quản lý đơn đặt</p>
            </div>
        </div>
        <div class="pos-header-right">
            <div class="pos-stats-pill">
                <span class="pos-stat-item">
                    <span class="pos-stat-dot dot-warning"></span>
                    <span>@PendingOrders.Count Chờ xử lý</span>
                </span>
                <div class="pos-stat-divider"></div>
                <span class="pos-stat-item">
                    <span class="pos-stat-dot dot-info"></span>
                    <span>@PaidOrders.Count Đã thanh toán</span>
                </span>
                <div class="pos-stat-divider"></div>
                <span class="pos-stat-item">
                    <span class="pos-stat-dot dot-info"></span>
                    <span>@PreparingOrders.Count Đang pha chế</span>
                </span>
                <div class="pos-stat-divider"></div>
                <span class="pos-stat-item">
                    <span class="pos-stat-dot dot-success"></span>
                    <span>@CompletedOrders.Count Hoàn thành</span>
                </span>
            </div>
            <div class="pos-connection-badge @(isConnected ? "connected" : "disconnected")">
                <span class="connection-dot"></span>
                <span>@(isConnected ? "Trực tuyến" : "Mất kết nối")</span>
            </div>
            <button class="pos-exit-btn" @onclick="GoBack">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                Thoát POS
            </button>
        </div>
    </header>

    <!-- Kanban Board -->
    @if (isLoading)
    {
        <div class="pos-loading">
            <div class="pos-loading-spinner"></div>
            <p>Đang tải đơn hàng...</p>
        </div>
    }
    else
    {
        <div class="kanban-board">
            <!-- Column: Chờ xử lý -->
            <div class="kanban-column col-pending">
                <div class="kanban-col-header">
                    <div class="kanban-col-title-wrap">
                        <div class="kanban-col-icon icon-pending">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                            </svg>
                        </div>
                        <span class="kanban-col-title">Chờ xử lý</span>
                    </div>
                    <span class="kanban-badge badge-pending">@PendingOrders.Count</span>
                </div>
                <div class="kanban-cards">
                    @if (!PendingOrders.Any())
                    {
                        <div class="kanban-empty">
                            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                            </svg>
                            <p>Không có đơn chờ</p>
                        </div>
                    }
                    @foreach (var order in PendingOrders)
                    {
                        <div class="kanban-card card-pending">
                            <div class="kanban-card-header">
                                <div class="order-id">#ORD-@order.OrderId</div>
                                <div class="order-time">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                                    </svg>
                                    @order.OrderDate.ToString("HH:mm")
                                </div>
                            </div>
                            <div class="kanban-card-meta">
                                <div class="meta-item">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="3"/>
                                    </svg>
                                    @(string.IsNullOrEmpty(order.TableNumber) ? "Quầy" : "Bàn " + order.TableNumber)
                                </div>
                                <div class="meta-item">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/>
                                    </svg>
                                    @order.Payment?.PaymentMethodName
                                </div>
                            </div>
                            <div class="kanban-divider"></div>
                            <ul class="order-items-list">
                                @foreach (var item in order.Items)
                                {
                                    <li class="order-item">
                                        <span class="item-qty">@item.Quantity</span>
                                        <span class="item-name">@item.DrinkName</span>
                                        <span class="item-opts">đá @item.IceLevel% · đường @item.SweetnessLevel%@(string.IsNullOrEmpty(item.ItemNote) ? "" : $" · {item.ItemNote}")</span>
                                    </li>
                                }
                            </ul>
                            <div class="kanban-divider"></div>
                            <div class="kanban-card-footer">
                                <div class="order-total">@order.FinalAmount.ToString("N0")đ</div>
                                <div class="card-actions">
                                    @if (order.Payment != null && order.Payment.PaymentMethod == 0 && order.Payment.PaymentStatus == 0)
                                    {
                                        <button class="btn-kanban btn-accept" @onclick="() => ConfirmCashPayment(order.OrderId)">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                                <polyline points="20 6 9 17 4 12"/>
                                            </svg>
                                            Thu tiền
                                        </button>
                                    }
                                    <button class="btn-kanban btn-cancel" @onclick="() => CancelOrder(order.OrderId, order.SessionId)" title="Hủy đơn">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Column: Đã thanh toán -->
            <div class="kanban-column col-paid">
                <div class="kanban-col-header">
                    <div class="kanban-col-title-wrap">
                        <div class="kanban-col-icon icon-paid">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </div>
                        <span class="kanban-col-title">Đã thanh toán</span>
                    </div>
                    <span class="kanban-badge badge-paid">@PaidOrders.Count</span>
                </div>
                <div class="kanban-cards">
                    @if (!PaidOrders.Any())
                    {
                        <div class="kanban-empty">
                            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>
                            </svg>
                            <p>Trống</p>
                        </div>
                    }
                    @foreach (var order in PaidOrders)
                    {
                        <div class="kanban-card card-paid">
                            <div class="kanban-card-header">
                                <div class="order-id">#ORD-@order.OrderId</div>
                                <div class="order-time">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                                    </svg>
                                    @order.OrderDate.ToString("HH:mm")
                                </div>
                            </div>
                            <div class="kanban-card-meta">
                                <div class="meta-item">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="3"/>
                                    </svg>
                                    @(string.IsNullOrEmpty(order.TableNumber) ? "Quầy" : "Bàn " + order.TableNumber)
                                </div>
                                <div class="meta-item text-success">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="20 6 9 17 4 12"/>
                                    </svg>
                                    Đã thanh toán
                                </div>
                            </div>
                            <div class="kanban-divider"></div>
                            <ul class="order-items-list">
                                @foreach (var item in order.Items)
                                {
                                    <li class="order-item">
                                        <span class="item-qty">@item.Quantity</span>
                                        <span class="item-name">@item.DrinkName</span>
                                        <span class="item-opts">đá @item.IceLevel% · đường @item.SweetnessLevel%@(string.IsNullOrEmpty(item.ItemNote) ? "" : $" · {item.ItemNote}")</span>
                                    </li>
                                }
                            </ul>
                            <div class="kanban-divider"></div>
                            <div class="kanban-card-footer">
                                <div class="order-total">@order.FinalAmount.ToString("N0")đ</div>
                                <div class="card-actions">
                                    <button class="btn-kanban btn-accept" @onclick="() => UpdateOrderStatus(order.OrderId, 1)">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                            <polyline points="20 6 9 17 4 12"/>
                                        </svg>
                                        Pha chế
                                    </button>
                                    <button class="btn-kanban btn-cancel" @onclick="() => CancelOrder(order.OrderId, order.SessionId)" title="Hủy đơn">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Column: Đang pha chế -->
            <div class="kanban-column col-preparing">
                <div class="kanban-col-header">
                    <div class="kanban-col-title-wrap">
                        <div class="kanban-col-icon icon-preparing">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
                                <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
                            </svg>
                        </div>
                        <span class="kanban-col-title">Đang pha chế</span>
                    </div>
                    <span class="kanban-badge badge-preparing">@PreparingOrders.Count</span>
                </div>
                <div class="kanban-cards">
                    @if (!PreparingOrders.Any())
                    {
                        <div class="kanban-empty">
                            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
                            </svg>
                            <p>Chưa có đơn đang làm</p>
                        </div>
                    }
                    @foreach (var order in PreparingOrders)
                    {
                        <div class="kanban-card card-preparing">
                            <div class="kanban-card-header">
                                <div class="order-id order-id-preparing">#ORD-@order.OrderId</div>
                                <div class="order-time">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                                    </svg>
                                    @order.OrderDate.ToString("HH:mm")
                                </div>
                            </div>
                            <div class="kanban-card-meta">
                                <div class="meta-item">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="3"/>
                                    </svg>
                                    @(string.IsNullOrEmpty(order.TableNumber) ? "Quầy" : "Bàn " + order.TableNumber)
                                </div>
                            </div>
                            <div class="kanban-divider"></div>
                            <ul class="order-items-list">
                                @foreach (var item in order.Items)
                                {
                                    <li class="order-item">
                                        <span class="item-qty">@item.Quantity×</span>
                                        <span class="item-name">@item.DrinkName</span>
                                        <span class="item-opts">đá @item.IceLevel% · đường @item.SweetnessLevel%@(string.IsNullOrEmpty(item.ItemNote) ? "" : $" · {item.ItemNote}")</span>
                                    </li>
                                }
                            </ul>
                            <div class="kanban-divider"></div>
                            <div class="kanban-card-footer">
                                <div class="order-total order-total-preparing">@order.FinalAmount.ToString("N0")đ</div>
                                <button class="btn-kanban btn-complete" @onclick="() => UpdateOrderStatus(order.OrderId, 2)">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <polyline points="20 6 9 17 4 12"/>
                                    </svg>
                                    Hoàn thành
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Column: Đã hoàn thành -->
            <div class="kanban-column col-completed">
                <div class="kanban-col-header">
                    <div class="kanban-col-title-wrap">
                        <div class="kanban-col-icon icon-completed">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                                <polyline points="22 4 12 14.01 9 11.01"/>
                            </svg>
                        </div>
                        <span class="kanban-col-title">Đã hoàn thành</span>
                    </div>
                    <span class="kanban-badge badge-completed">@CompletedOrders.Count</span>
                </div>
                <div class="kanban-cards">
                    @if (!CompletedOrders.Any())
                    {
                        <div class="kanban-empty">
                            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                                <polyline points="22 4 12 14.01 9 11.01"/>
                            </svg>
                            <p>Chưa có đơn hoàn thành</p>
                        </div>
                    }
                    @foreach (var order in CompletedOrders)
                    {
                        <div class="kanban-card card-completed">
                            <div class="kanban-card-header">
                                <div class="order-id order-id-completed">#ORD-@order.OrderId</div>
                                <div class="order-time">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                                    </svg>
                                    @order.OrderDate.ToString("HH:mm")
                                </div>
                            </div>
                            <div class="kanban-card-meta">
                                <div class="meta-item">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="3"/>
                                    </svg>
                                    @(string.IsNullOrEmpty(order.TableNumber) ? "Quầy" : "Bàn " + order.TableNumber)
                                </div>
                                <div class="completed-check">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <polyline points="20 6 9 17 4 12"/>
                                    </svg>
                                    Đã giao
                                </div>
                            </div>
                            <div class="kanban-divider"></div>
                            <div class="kanban-card-footer d-flex justify-content-between align-items-center w-100">
                                <div class="completed-amount">@order.FinalAmount.ToString("N0")đ</div>
                                <button class="btn-kanban btn-accept" @onclick="() => PrintInvoice(order)" style="background-color: #f0fdf4; color: #16a34a; border-color: #bbf7d0; font-size: 11px; padding: 4px 8px; border-radius: 6px;">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1">
                                        <polyline points="6 9 6 2 18 2 18 9"/>
                                        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
                                        <rect x="6" y="14" width="12" height="8"/>
                                    </svg>
                                    In hóa đơn
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private bool isConnected = false;
    private List<OrderDto> activeOrders = new();
    private HubConnection? hubConnection;
    private List<SystemConfigDto> configs = new();

    private List<OrderDto> PendingOrders => activeOrders.Where(o => o.OrderStatus == 0 && (o.Payment == null || o.Payment.PaymentStatus == 0)).ToList();
    private List<OrderDto> PaidOrders => activeOrders.Where(o => o.OrderStatus == 0 && o.Payment != null && o.Payment.PaymentStatus == 1).ToList();
    private List<OrderDto> PreparingOrders => activeOrders.Where(o => o.OrderStatus == 1).ToList();
    private List<OrderDto> CompletedOrders => activeOrders.Where(o => o.OrderStatus == 2).ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
        await LoadConfig();
        await SetupSignalR();
    }

    private async Task LoadConfig()
    {
        try
        {
            configs = await ConfigApi.GetConfigsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Lỗi khi tải cấu hình");
        }
    }

    private async Task LoadOrders()
    {
        try
        {
            isLoading = true;
            activeOrders = await OrderApi.GetActiveOrdersAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SetupSignalR()
    {
        var apiBaseUrl = Config["BackendApiUrl"] ?? "http://localhost:5153";
        var token = await LocalStorage.GetItemAsync("authToken");

        hubConnection = new HubConnectionBuilder()
            .WithUrl($"{apiBaseUrl.TrimEnd('/')}/orderhub", options =>
            {
                if (!string.IsNullOrEmpty(token))
                {
                    options.AccessTokenProvider = () => Task.FromResult<string?>(token);
                }
            })
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<OrderDto>("ReceiveNewOrder", (order) =>
        {
            if (!activeOrders.Any(o => o.OrderId == order.OrderId))
            {
                activeOrders.Insert(0, order);
                StateHasChanged();
            }
        });

        hubConnection.On<StatusUpdateEvent>("ReceiveStatusUpdateAtPOS", (data) =>
        {
            var order = activeOrders.FirstOrDefault(o => o.OrderId == data.OrderId);
            if (order != null)
            {
                order.OrderStatus = data.Status;
                order.OrderStatusName = data.StatusName;
                if (data.PaymentStatus.HasValue && order.Payment != null)
                {
                    order.Payment.PaymentStatus = data.PaymentStatus.Value;
                }
                StateHasChanged();
            }
        });

        hubConnection.Closed += (error) => { isConnected = false; StateHasChanged(); return Task.CompletedTask; };
        hubConnection.Reconnected += (id) => { isConnected = true; StateHasChanged(); return Task.CompletedTask; };

        try
        {
            await hubConnection.StartAsync();
            isConnected = true;
            await hubConnection.InvokeAsync("JoinStaffGroup");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Lỗi khi kết nối SignalR");
            isConnected = false;
        }
    }

    private async Task UpdateOrderStatus(int orderId, byte status)
    {
        bool success = await OrderApi.UpdateOrderStatusAsync(orderId, status);
        if (success)
        {
            var order = activeOrders.FirstOrDefault(o => o.OrderId == orderId);
            if (order != null) { order.OrderStatus = status; StateHasChanged(); }
        }
    }

    private async Task CancelOrder(int orderId, Guid sessionId)
    {
        bool success = await OrderApi.CancelOrderAsync(orderId, sessionId);
        if (success)
        {
            var order = activeOrders.FirstOrDefault(o => o.OrderId == orderId);
            if (order != null) { activeOrders.Remove(order); StateHasChanged(); }
        }
    }

    private async Task ConfirmCashPayment(int orderId)
    {
        bool success = await OrderApi.ConfirmCashPaymentAsync(orderId);
        if (success)
        {
            var order = activeOrders.FirstOrDefault(o => o.OrderId == orderId);
            if (order != null && order.Payment != null)
            {
                order.Payment.PaymentStatus = 1; // Success
                StateHasChanged();
            }
        }
    }

    private async Task PrintInvoice(OrderDto order)
    {
        var storeName = configs.FirstOrDefault(c => c.ConfigKey == "StoreName")?.ConfigValue ?? "NGOC UWU COFFEE";
        var storeAddress = configs.FirstOrDefault(c => c.ConfigKey == "StoreAddress")?.ConfigValue ?? "Đ/c: 123 Đường Sách, TP. Hồ Chí Minh";
        var storePhone = configs.FirstOrDefault(c => c.ConfigKey == "StorePhone")?.ConfigValue ?? "SĐT: 0123.456.789";
        var storeWifi = configs.FirstOrDefault(c => c.ConfigKey == "StoreWifi")?.ConfigValue;

        var sb = new System.Text.StringBuilder();
        sb.Append("<div class=\"invoice-box\">");
        sb.Append("<div class=\"text-center\">");
        sb.Append($"<div class=\"header-title\">{storeName}</div>");
        sb.Append($"<div>{storeAddress}</div>");
        sb.Append($"<div>{storePhone}</div>");
        if (!string.IsNullOrEmpty(storeWifi))
        {
            sb.Append($"<div>WiFi: {storeWifi}</div>");
        }
        sb.Append("<div class=\"divider\"></div>");
        sb.Append("<div class=\"bold\">HÓA ĐƠN THANH TOÁN</div>");
        sb.Append($"<div>Mã đơn: #ORD-{order.OrderId}</div>");
        sb.Append($"<div>Ngày: {order.OrderDate:dd/MM/yyyy HH:mm}</div>");
        sb.Append($"<div>Bàn: {order.TableNumber ?? "Quầy"}</div>");
        sb.Append("</div>");
        sb.Append("<div class=\"divider\"></div>");
        sb.Append("<table class=\"item-table\">");
        sb.Append("<thead><tr><th>Món</th><th class=\"text-right\">SL</th><th class=\"text-right\">T.Tiền</th></tr></thead>");
        sb.Append("<tbody>");
        foreach (var item in order.Items)
        {
            sb.Append("<tr>");
            sb.Append($"<td>{item.DrinkName}");
            if (!string.IsNullOrEmpty(item.SizeName))
            {
                sb.Append($"<br/><small>Size: {item.SizeName}</small>");
            }
            sb.Append($"<br/><small>Đá: {item.IceLevel}% · Đường: {item.SweetnessLevel}%");
            if (item.ToppingNames != null && item.ToppingNames.Any())
            {
                sb.Append($" · Topping: {string.Join(", ", item.ToppingNames)}");
            }
            if (!string.IsNullOrEmpty(item.ItemNote))
            {
                sb.Append($" · {item.ItemNote}");
            }
            sb.Append("</small></td>");
            sb.Append($"<td class=\"text-right\">{item.Quantity}</td>");
            sb.Append($"<td class=\"text-right\">{(item.UnitPrice * item.Quantity):N0}đ</td>");
            sb.Append("</tr>");
        }
        sb.Append("</tbody></table>");
        sb.Append("<div class=\"divider\"></div>");
        sb.Append("<div style=\"display: flex; justify-content: space-between;\">");
        sb.Append("<span>Tổng cộng:</span>");
        sb.Append($"<span>{order.TotalAmount:N0}đ</span>");
        sb.Append("</div>");
        sb.Append("<div style=\"display: flex; justify-content: space-between;\">");
        sb.Append("<span>Giảm giá:</span>");
        sb.Append($"<span>{order.DiscountAmount:N0}đ</span>");
        sb.Append("</div>");
        sb.Append("<div style=\"display: flex; justify-content: space-between; font-weight: bold;\">");
        sb.Append("<span>Thành tiền:</span>");
        sb.Append($"<span>{order.FinalAmount:N0}đ</span>");
        sb.Append("</div>");
        sb.Append("<div class=\"divider\"></div>");
        sb.Append("<div class=\"text-center\" style=\"margin-top: 15px; font-style: italic;\">");
        sb.Append("Cảm ơn Quý khách. Hẹn gặp lại!");
        sb.Append("</div>");
        sb.Append("</div>");

        await JSRuntime.InvokeVoidAsync("printInvoice", sb.ToString());
    }

    private void GoBack() => NavigationManager.NavigateTo("/account");

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null) await hubConnection.DisposeAsync();
    }

    public class StatusUpdateEvent
    {
        public int OrderId { get; set; }
        public byte Status { get; set; }
        public string StatusName { get; set; } = string.Empty;
        public byte? PaymentStatus { get; set; }
    }
}

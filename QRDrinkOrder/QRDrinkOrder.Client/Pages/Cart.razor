@page "/cart"
@inject QRDrinkOrder.Client.Services.CartState CartState
@inject QRDrinkOrder.Client.Services.OrderStateService OrderState
@inject QRDrinkOrder.Client.Services.OrderApiClient OrderApi
@inject QRDrinkOrder.Client.Services.CouponApiClient CouponApi
@inject QRDrinkOrder.Client.Services.MembershipApiClient MembershipApi
@inject QRDrinkOrder.Client.Services.PushNotificationService PushService
@using QRDrinkOrder.Shared.DTOs.Requests
@using QRDrinkOrder.Shared.Enums
@using QRDrinkOrder.Client.Services
@inject Microsoft.AspNetCore.Components.NavigationManager NavigationManager
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider

<PageTitle>Xác nhận đơn hàng - Ngoc UwU Coffee</PageTitle>

<div class="mb-3 d-flex align-items-center bg-white p-3 border-bottom sticky-top" style="margin: -1rem -1rem 1rem -1rem; z-index: 10;">
    <a href="/" class="text-decoration-none text-dark me-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
    </a>
    <span class="fw-bold fs-5 mb-0 mx-auto" style="transform: translateX(-12px);">Xác nhận đơn hàng</span>
</div>

@if (!CartState.Items.Any())
{
    <div class="text-center py-5 bg-white rounded" style="border: 1px solid #f0f0f0;">
        <img src="/images/placeholder.png" alt="Empty Cart" style="width: 150px; opacity: 0.8;" class="mb-3" onerror="this.onerror=null; this.src='/images/placeholder.png';" />
        <h6 class="fw-bold">Giỏ hàng của bạn đang trống</h6>
        <p class="text-muted small">Hãy chọn thêm các món ngon nhé!</p>
        <a href="/" class="btn btn-primary mt-3 px-4">Tiếp tục chọn món</a>
    </div>
}
else
{
    <div class="row">
        <div class="col-md-7 mb-4">
            <!-- Khối thông tin nhận hàng -->
            <div class="tch-card p-3 mb-3">
                <h6 class="fw-bold mb-3">Tùy chọn nhận hàng</h6>
                
                <div class="d-flex gap-2 mb-3">
                    <button class="btn @(orderType == OrderType.Pickup ? "btn-outline-primary active" : "btn-outline-secondary") flex-fill fw-bold rounded-pill" @onclick="() => orderType = OrderType.Pickup">Mang đi</button>
                    <button class="btn @(orderType == OrderType.DineIn ? "btn-outline-primary active" : "btn-outline-secondary") flex-fill fw-bold rounded-pill" @onclick="() => orderType = OrderType.DineIn">Uống tại bàn</button>
                </div>

                @if (orderType == OrderType.DineIn)
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-secondary">Số bàn đang ngồi <span class="text-danger">*</span></label>
                        <input type="text" class="form-control bg-light border-0" @bind="tableNumber" placeholder="Nhập số bàn (Ví dụ: Bàn 12)" />
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label fw-bold small text-secondary">Số điện thoại <span class="text-danger">*</span></label>
                    <input type="tel" class="form-control bg-light border-0" @bind="phone" @onblur="CheckMembership" placeholder="Vui lòng nhập số điện thoại/Phone number" />
                </div>
                
                @if (membership != null && membership.Points > 0)
                {
                    <div class="bg-light p-3 rounded mb-3 border border-warning" style="background-color: #fff9e6 !important;">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <h6 class="fw-bold mb-0 text-warning d-flex align-items-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-star-fill me-1" viewBox="0 0 16 16">
                                      <path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/>
                                    </svg>
                                    Tích điểm
                                </h6>
                                <small class="text-muted">Bạn có <strong>@membership.Points</strong> điểm</small>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="usePointsSwitch" @bind="usePoints" @onclick="TogglePoints">
                                <label class="form-check-label small fw-bold" for="usePointsSwitch">Dùng điểm</label>
                            </div>
                        </div>
                        
                        @if (usePoints)
                        {
                            <div class="d-flex align-items-center mt-2 gap-2">
                                <input type="number" class="form-control form-control-sm" style="width: 80px;" @bind="pointsToUse" @bind:event="oninput" min="1" max="@membership.Points" />
                                <span class="small text-secondary">điểm để giảm <strong>@((pointsToUse * 1000).ToString("N0"))đ</strong></span>
                            </div>
                        }
                    </div>
                }
                
                @if (isEmployee)
                {
                    <div class="bg-light p-3 rounded mb-3 border border-primary" style="background-color: #e6f0ff !important;">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <h6 class="fw-bold mb-0 text-primary d-flex align-items-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-badge me-1" viewBox="0 0 16 16">
                                      <path d="M6.5 2a.5.5 0 0 0 0 1h3a.5.5 0 0 0 0-1h-3zM11 8a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                                      <path d="M4.5 0A2.5 2.5 0 0 0 2 2.5V14a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V2.5A2.5 2.5 0 0 0 11.5 0h-7zM3 2.5A1.5 1.5 0 0 1 4.5 1h7A1.5 1.5 0 0 1 13 2.5v10.795a4.224 4.224 0 0 0-.776-.492C11.392 12.387 10.063 12 8 12s-3.392.387-4.224.803a4.224 4.224 0 0 0-.776.492V2.5z"/>
                                    </svg>
                                    Ưu đãi Nhân viên
                                </h6>
                                <small class="text-muted">Giảm 50% cho đơn hàng này</small>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="useEmployeeBenefitSwitch" @bind="useEmployeeBenefit" disabled="@(appliedCoupon != null)">
                                <label class="form-check-label small fw-bold" for="useEmployeeBenefitSwitch">Sử dụng</label>
                            </div>
                        </div>
                        @if (appliedCoupon != null)
                        {
                            <div class="small text-danger mt-1">Không thể dùng chung với mã giảm giá khác.</div>
                        }
                    </div>
                }
                
                <div class="mb-2">
                    <label class="form-label fw-bold small text-secondary">Ghi chú</label>
                    <input type="text" class="form-control bg-light border-0" @bind="orderNote" placeholder="Nhập ghi chú" />
                </div>
            </div>

            <!-- Khối danh sách món -->
            <div class="tch-card p-3 mb-3">
                <h6 class="fw-bold mb-3">Sản phẩm đã chọn</h6>
                @foreach (var item in CartState.Items)
                {
                    <div class="d-flex mb-3 align-items-center">
                        <button class="btn btn-link text-secondary p-0 me-3" @onclick="() => CartState.RemoveItem(item)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x-circle" viewBox="0 0 16 16">
                                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                                <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
                            </svg>
                        </button>
                        <div class="fw-bold me-2">x @item.Quantity</div>
                        <img src="@(string.IsNullOrEmpty(item.Drink.ImageUrl) ? "/images/placeholder.png" : item.Drink.ImageUrl)" class="rounded" style="width: 45px; height: 45px; object-fit: cover;" />
                        <div class="ms-3 flex-grow-1">
                            <div class="fw-bold" style="font-size: 0.95rem;">@item.Drink.DrinkName</div>
                            <div class="small text-secondary">
                                Đá: @item.IceLevel%, Đường: @item.SweetnessLevel%
                                @if (item.SelectedSize != null)
                                {
                                    <text> | Size: @item.SelectedSize.Name</text>
                                }
                            </div>
                            @if (item.SelectedToppings.Any())
                            {
                                <div class="small text-secondary">
                                    Topping: @string.Join(", ", item.SelectedToppings.Select(t => t.Name))
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(item.ItemNote))
                            {
                                <div class="small text-secondary">Ghi chú: @item.ItemNote</div>
                            }
                        </div>
                        <div class="fw-bold text-end">@item.TotalPrice.ToString("N0")đ</div>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-5">
            <!-- Tóm tắt hóa đơn & Khuyến mãi -->
            <div class="tch-card p-3 mb-3">
                <h6 class="fw-bold mb-3 border-bottom pb-2">Tổng cộng</h6>
                
                <div class="mb-3 d-flex align-items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="var(--tch-orange)" class="bi bi-ticket-perforated flex-shrink-0" viewBox="0 0 16 16">
                        <path d="M4 4.85v.9h1v-.9H4Zm7 0v.9h1v-.9h-1Zm-7 1.8v.9h1v-.9H4Zm7 0v.9h1v-.9h-1Zm-7 1.8v.9h1v-.9H4Zm7 0v.9h1v-.9h-1Zm-7 1.8v.9h1v-.9H4Zm7 0v.9h1v-.9h-1Z"/>
                        <path d="M1.5 3A1.5 1.5 0 0 0 0 4.5V6a.5.5 0 0 0 .5.5 1.5 1.5 0 1 1 0 3 .5.5 0 0 0-.5.5v1.5A1.5 1.5 0 0 0 1.5 13h13a1.5 1.5 0 0 0 1.5-1.5V10a.5.5 0 0 0-.5-.5 1.5 1.5 0 0 1 0-3A.5.5 0 0 0 16 6V4.5A1.5 1.5 0 0 0 14.5 3h-13ZM1 4.5a.5.5 0 0 1 .5-.5h13a.5.5 0 0 1 .5.5v1.05a2.5 2.5 0 0 0 0 4.9v1.05a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-1.05a2.5 2.5 0 0 0 0-4.9V4.5Z"/>
                    </svg>
                    <input type="text" class="form-control text-uppercase" style="border: 1px dashed var(--tch-orange);" @bind="couponCode" placeholder="Mã giảm giá (nếu có)" disabled="@(appliedCoupon != null)" />
                    @if (appliedCoupon == null)
                    {
                        <button class="btn btn-outline-primary px-3" @onclick="ApplyCoupon" disabled="@isApplyingCoupon">
                            @if (isApplyingCoupon) { <span class="spinner-border spinner-border-sm"></span> }
                            else { <span>Áp dụng</span> }
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-outline-danger px-3" @onclick="RemoveCoupon">Bỏ</button>
                    }
                </div>
                @if (!string.IsNullOrEmpty(couponMessage))
                {
                    <div class="small fw-bold mb-3 text-@(appliedCoupon != null ? "success" : "danger")">@couponMessage</div>
                }

                @if (appliedCoupon != null)
                {
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-secondary small">Tạm tính</span>
                        <span class="text-secondary small text-decoration-line-through">@CartState.GetTotalAmount().ToString("N0")đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-success small fw-bold">Khuyến mãi</span>
                        <span class="text-success fw-bold">-@discountAmount.ToString("N0")đ</span>
                    </div>
                }
                
                @if (usePoints && pointsToUse > 0)
                {
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-warning small fw-bold">Dùng điểm (@pointsToUse điểm)</span>
                        <span class="text-warning fw-bold">-@((pointsToUse * 1000).ToString("N0"))đ</span>
                    </div>
                }
                
                @if (isEmployee && useEmployeeBenefit && appliedCoupon == null)
                {
                    var employeeDiscount = (CartState.GetTotalAmount() - discountAmount - (usePoints ? pointsToUse * 1000 : 0)) * 0.5m;
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-primary small fw-bold">Ưu đãi nhân viên (-50%)</span>
                        <span class="text-primary fw-bold">-@employeeDiscount.ToString("N0")đ</span>
                    </div>
                }
                
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-secondary fw-bold">Thành tiền</span>
                    <span class="fw-bold fs-5" style="color: var(--tch-orange);">@GetFinalAmount().ToString("N0")đ</span>
                </div>
            </div>

            <!-- Phương thức thanh toán -->
            <div class="tch-card p-3 mb-4">
                <h6 class="fw-bold mb-3">Phương thức thanh toán</h6>
                <div class="form-check mb-3 d-flex align-items-center" @onclick="() => paymentMethod = (byte)PaymentMethod.SePay" style="cursor: pointer;">
                    <input class="form-check-input me-2" type="radio" name="paymentMethod" checked="@(paymentMethod == (byte)PaymentMethod.SePay)">
                    <label class="form-check-label d-flex align-items-center flex-grow-1">
                        <img src="/images/placeholder.png" alt="MoMo" width="24" class="me-2 rounded" />
                        Chuyển khoản QR
                    </label>
                </div>
                <div class="form-check d-flex align-items-center" @onclick="() => paymentMethod = (byte)PaymentMethod.Cash" style="cursor: pointer;">
                    <input class="form-check-input me-2" type="radio" name="paymentMethod" checked="@(paymentMethod == (byte)PaymentMethod.Cash)">
                    <label class="form-check-label d-flex align-items-center flex-grow-1">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-cash me-2 text-success" viewBox="0 0 16 16">
                            <path d="M8 10a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/>
                            <path d="M0 4a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V4zm3 0a2 2 0 0 1-2 2v4a2 2 0 0 1 2 2h10a2 2 0 0 1 2-2V6a2 2 0 0 1-2-2H3z"/>
                        </svg>
                        Tiền mặt
                    </label>
                </div>
            </div>

            <!-- Fix to bottom button on mobile, sticky on PC -->
            <div class="glass-panel p-3 sticky-bottom mt-3" style="margin: 0 -1rem; z-index: 100; border-top-left-radius: var(--tch-radius-md); border-top-right-radius: var(--tch-radius-md);">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger small py-2 mb-2">@errorMessage</div>
                }
                
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                        <div class="text-secondary small fw-bold">Thành tiền</div>
                        <div class="fw-bold fs-5" style="color: var(--tch-orange);">@GetFinalAmount().ToString("N0")đ</div>
                    </div>
                    <button class="btn btn-primary px-5 py-3 fw-bold" style="border-radius: 24px;" @onclick="SubmitOrder" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span> <span>Đang đặt...</span>
                        }
                        else
                        {
                            <span>Đặt hàng</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string phone = "";
    private string couponCode = "";
    private string orderNote = "";
    private byte paymentMethod = (byte)PaymentMethod.SePay;
    
    private bool isSubmitting = false;
    private string errorMessage = "";
    
    private OrderType orderType = OrderType.Pickup;
    private string tableNumber = "";
    
    private CouponDto? appliedCoupon = null;
    private decimal discountAmount = 0;
    private string couponMessage = "";
    private bool isApplyingCoupon = false;
    
    private MembershipDto? membership;
    private bool usePoints = false;
    private int pointsToUse = 0;
    
    private bool isEmployee = false;
    private bool useEmployeeBenefit = false;

    protected override async Task OnInitializedAsync()
    {
        CartState.OnChange += StateHasChanged;
        orderType = OrderState.CurrentOrderType;
        tableNumber = OrderState.TableNumber ?? "";
        
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true && authState.User.IsInRole("Employee"))
        {
            isEmployee = true;
        }
    }
    
    private decimal GetFinalAmount()
    {
        var total = CartState.GetTotalAmount();
        decimal pointDiscount = usePoints ? pointsToUse * 1000 : 0;
        
        var final = total - discountAmount - pointDiscount;
        if (isEmployee && useEmployeeBenefit && appliedCoupon == null)
        {
            final = final * 0.5m;
        }
        
        return final > 0 ? final : 0;
    }
    
    private async Task CheckMembership()
    {
        if (!string.IsNullOrWhiteSpace(phone) && phone.Length >= 9)
        {
            membership = await MembershipApi.GetMembershipByPhoneAsync(phone);
            if (membership != null && pointsToUse > membership.Points)
            {
                pointsToUse = membership.Points;
            }
        }
    }
    
    private void TogglePoints()
    {
        usePoints = !usePoints;
        if (usePoints && membership != null)
        {
            pointsToUse = membership.Points; // Default to max points
        }
        else
        {
            pointsToUse = 0;
        }
    }
    
    private async Task ApplyCoupon()
    {
        if (string.IsNullOrWhiteSpace(couponCode)) return;
        
        if (string.IsNullOrWhiteSpace(phone))
        {
            couponMessage = "Vui lòng nhập số điện thoại trước khi áp dụng mã.";
            return;
        }

        isApplyingCoupon = true;
        couponMessage = "";
        try
        {
            var req = new ApplyCouponRequest
            {
                CouponCode = couponCode.ToUpper().Trim(),
                OrderAmount = CartState.GetTotalAmount(),
                Phone = phone
            };
            
            var result = await CouponApi.ApplyCouponAsync(req);
            if (result != null)
            {
                appliedCoupon = result;
                if (result.DiscountType == 0) // Fixed
                {
                    discountAmount = result.DiscountValue;
                }
                else // Percentage
                {
                    var calculated = CartState.GetTotalAmount() * (result.DiscountValue / 100m);
                    if (result.MaxDiscountAmount.HasValue && calculated > result.MaxDiscountAmount.Value)
                        calculated = result.MaxDiscountAmount.Value;
                    discountAmount = calculated;
                }
                couponMessage = $"Áp dụng thành công! Giảm {discountAmount.ToString("N0")}đ";
            }
            else
            {
                couponMessage = "Mã giảm giá không hợp lệ hoặc không đủ điều kiện.";
                appliedCoupon = null;
                discountAmount = 0;
            }
        }
        catch
        {
            couponMessage = "Mã không hợp lệ hoặc đã hết hạn.";
            appliedCoupon = null;
            discountAmount = 0;
        }
        finally
        {
            isApplyingCoupon = false;
        }
    }

    private void RemoveCoupon()
    {
        appliedCoupon = null;
        discountAmount = 0;
        couponCode = "";
        couponMessage = "";
    }

    private async Task SubmitOrder()
    {
        if (string.IsNullOrWhiteSpace(phone))
        {
            errorMessage = "Vui lòng nhập số điện thoại của bạn.";
            return;
        }

        if (orderType == OrderType.DineIn && string.IsNullOrWhiteSpace(tableNumber))
        {
            errorMessage = "Vui lòng nhập số bàn của bạn.";
            return;
        }

        try
        {
            isSubmitting = true;
            errorMessage = "";

            var tableStr = orderType == OrderType.DineIn ? $"Bàn {tableNumber.Replace("Bàn", "").Replace("bàn", "").Trim()}" : "Mang đi";

            var request = new CreateOrderRequest
            {
                Phone = phone.Trim(),
                TableNumber = tableStr,
                CouponCode = appliedCoupon != null ? appliedCoupon.CouponCode : (string.IsNullOrWhiteSpace(couponCode) ? null : couponCode.ToUpper().Trim()),
                PointsToUse = usePoints && pointsToUse > 0 ? pointsToUse : null,
                PaymentMethod = paymentMethod,
                Note = orderNote,
                Items = CartState.Items.Select(i => new OrderItemRequest
                {
                    DrinkId = i.Drink.DrinkId,
                    Quantity = i.Quantity,
                    SweetnessLevel = i.SweetnessLevel,
                    IceLevel = i.IceLevel,
                    ItemNote = i.ItemNote,
                    UnitPrice = i.UnitPrice,
                    SizeId = i.SelectedSize?.SizeId,
                    ToppingIds = i.SelectedToppings.Select(t => t.ToppingId).ToList()
                }).ToList(),
                UseEmployeeBenefit = useEmployeeBenefit
            };

            var result = await OrderApi.CreateOrderAsync(CartState.SessionId, request);
            
            if (result != null)
            {
                CartState.ClearCart();
                
                if (result.Payment != null && result.Payment.PaymentMethod == (byte)PaymentMethod.SePay)
                {
                    NavigationManager.NavigateTo($"/payment/{result.OrderId}");
                }
                else
                {
                    NavigationManager.NavigateTo($"/track-order/{result.OrderId}");
                }

                // Hỏi quyền thông báo đẩy (Background task)
                _ = PushService.SubscribeToNotificationsAsync(phone);
            }
            else
            {
                errorMessage = "Có lỗi xảy ra khi tạo đơn hàng. Vui lòng thử lại.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}


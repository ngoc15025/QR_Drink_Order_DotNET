@page "/admin/settings"
@attribute [Authorize(Roles = "Admin,Manager")]
@inject QRDrinkOrder.Client.Services.SystemConfigApiClient ConfigApi
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

@layout QRDrinkOrder.Client.Layout.AdminLayout

<PageTitle>Cấu hình Hệ thống - Ngoc UwU</PageTitle>

<style>
    /* AIDA & Bento Grid - GPT-Taste Aesthetics */
    .settings-cinematic-hero {
        margin-bottom: 2.5rem;
        animation: fadeDown 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    
    .settings-bento-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 1.5rem;
        grid-auto-flow: dense;
    }

    .bento-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 24px;
        padding: 2rem;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.03);
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        overflow: hidden;
        position: relative;
        opacity: 0;
        animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .bento-card:hover {
        transform: translateY(-4px) scale(1.01);
        box-shadow: 0 20px 40px rgba(255, 122, 0, 0.08);
        border-color: rgba(255, 122, 0, 0.2);
    }

    /* Grid spans */
    .bento-span-8 { grid-column: span 8; }
    .bento-span-4 { grid-column: span 4; }
    .bento-span-6 { grid-column: span 6; }
    .bento-span-12 { grid-column: span 12; }
    
    @@media (max-width: 991px) {
        .bento-span-8, .bento-span-4, .bento-span-6 { grid-column: span 12; }
    }

    .bento-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 1.5rem;
        color: #1a1a1a;
    }

    .bento-icon {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, rgba(255,122,0,0.1), rgba(255,122,0,0.05));
        color: #ff7a00;
        border-radius: 12px;
    }

    .bento-title {
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0;
    }

    .admin-input-bento {
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 16px;
        padding: 0.875rem 1.25rem;
        font-size: 1rem;
        font-weight: 500;
        color: #1a1a1a;
        transition: all 0.3s ease;
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
    }

    .admin-input-bento:focus {
        border-color: #ff7a00;
        background: #ffffff;
        box-shadow: 0 0 0 4px rgba(255, 122, 0, 0.1);
        outline: none;
    }

    .bento-label {
        font-size: 0.875rem;
        font-weight: 600;
        color: #666;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .bento-save-btn {
        background: #1a1a1a;
        color: white;
        border: none;
        padding: 1rem 2.5rem;
        font-weight: 600;
        border-radius: 50px;
        font-size: 1rem;
        transition: all 0.4s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .bento-save-btn:hover {
        background: #ff7a00;
        transform: scale(1.05);
        box-shadow: 0 10px 25px rgba(255, 122, 0, 0.3);
    }

    .bento-save-btn:disabled {
        background: #ccc;
        transform: none;
        box-shadow: none;
    }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    @@keyframes fadeDown {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Staggered animation delays */
    .delay-1 { animation-delay: 0.1s; }
    .delay-2 { animation-delay: 0.2s; }
    .delay-3 { animation-delay: 0.3s; }
</style>

<div class="px-md-4 pb-5">
    <div class="settings-cinematic-hero d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h1 class="fw-bolder mb-1" style="font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.03em;">Thiết lập Cửa hàng</h1>
            <p class="text-secondary fs-5 mb-0" style="font-weight: 500;">Định hình thương hiệu & kết nối của bạn.</p>
        </div>
        <button class="bento-save-btn" @onclick="SaveConfigs" disabled="@isSaving">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
            @(isSaving ? "Đang xử lý..." : "Lưu thay đổi")
        </button>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger rounded-4 border-0 shadow-sm mb-4">@errorMessage</div>
    }
    @if (showSuccess)
    {
        <div class="alert alert-success rounded-4 border-0 shadow-sm mb-4" style="background: rgba(40, 167, 69, 0.1); color: #28a745; border-left: 4px solid #28a745 !important;">
            <i class="bi bi-check-circle-fill me-2"></i> Lưu cấu hình thành công!
        </div>
    }

    @if (isLoading)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
        </div>
    }
    else
    {
        <div class="settings-bento-grid">
            
            <!-- Branding Card -->
            <div class="bento-card bento-span-8 delay-1">
                <div class="bento-header">
                    <div class="bento-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                    </div>
                    <h3 class="bento-title">Định danh Thương hiệu</h3>
                </div>
                <div class="row gx-4 gy-3">
                    <div class="col-md-6">
                        <label class="bento-label">Tên cửa hàng</label>
                        <input type="text" class="form-control admin-input-bento w-100" @bind="storeName" placeholder="Ngoc UwU Coffee" />
                    </div>
                    <div class="col-md-6">
                        <label class="bento-label">Hotline Liên hệ</label>
                        <input type="text" class="form-control admin-input-bento w-100" @bind="storePhone" placeholder="0123.456.789" />
                    </div>
                </div>
            </div>

            <!-- Network Card -->
            <div class="bento-card bento-span-4 delay-2">
                <div class="bento-header">
                    <div class="bento-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12.55a11 11 0 0 1 14.08 0"></path><path d="M1.42 9a16 16 0 0 1 21.16 0"></path><path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path><line x1="12" y1="20" x2="12.01" y2="20"></line></svg>
                    </div>
                    <h3 class="bento-title">Kết nối Mạng</h3>
                </div>
                <div class="mb-0">
                    <label class="bento-label">Mật khẩu Wi-Fi</label>
                    <input type="text" class="form-control admin-input-bento w-100" @bind="storeWifi" placeholder="Nhập pass wifi..." />
                </div>
            </div>

            <!-- Location Card -->
            <div class="bento-card bento-span-12 delay-3">
                <div class="bento-header">
                    <div class="bento-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                    </div>
                    <h3 class="bento-title">Vị trí Địa lý</h3>
                </div>
                <div class="mb-0">
                    <label class="bento-label">Địa chỉ chính thức</label>
                    <input type="text" class="form-control admin-input-bento w-100" @bind="storeAddress" placeholder="Số nhà, Tên đường, Phường/Xã..." />
                </div>
            </div>

        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private bool isSaving = false;
    private string errorMessage = "";
    private bool showSuccess = false;

    private List<SystemConfigDto> configs = new();

    private string storeName = "";
    private string storeAddress = "";
    private string storePhone = "";
    private string storeWifi = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadConfigs();
    }

    private async Task LoadConfigs()
    {
        try
        {
            configs = await ConfigApi.GetConfigsAsync();
            storeName = configs.FirstOrDefault(c => c.ConfigKey == "StoreName")?.ConfigValue ?? "";
            storeAddress = configs.FirstOrDefault(c => c.ConfigKey == "StoreAddress")?.ConfigValue ?? "";
            storePhone = configs.FirstOrDefault(c => c.ConfigKey == "StorePhone")?.ConfigValue ?? "";
            storeWifi = configs.FirstOrDefault(c => c.ConfigKey == "StoreWifi")?.ConfigValue ?? "";
        }
        catch (Exception ex)
        {
            errorMessage = "Không thể tải cấu hình: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveConfigs()
    {
        isSaving = true;
        errorMessage = "";
        showSuccess = false;

        try
        {
            await ConfigApi.UpdateConfigAsync("StoreName", new SystemConfigDto { ConfigKey = "StoreName", ConfigValue = storeName, Description = "Tên cửa hàng" });
            await ConfigApi.UpdateConfigAsync("StoreAddress", new SystemConfigDto { ConfigKey = "StoreAddress", ConfigValue = storeAddress, Description = "Địa chỉ cửa hàng" });
            await ConfigApi.UpdateConfigAsync("StorePhone", new SystemConfigDto { ConfigKey = "StorePhone", ConfigValue = storePhone, Description = "Số điện thoại liên hệ" });
            await ConfigApi.UpdateConfigAsync("StoreWifi", new SystemConfigDto { ConfigKey = "StoreWifi", ConfigValue = storeWifi, Description = "Lời chào cuối hóa đơn" });
            
            showSuccess = true;
            StateHasChanged();
            
            await Task.Delay(3000);
            showSuccess = false;
        }
        catch (Exception ex)
        {
            errorMessage = "Đã xảy ra lỗi khi lưu cấu hình: " + ex.Message;
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }
}

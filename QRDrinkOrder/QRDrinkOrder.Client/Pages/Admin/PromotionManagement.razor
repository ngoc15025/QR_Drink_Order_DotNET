@page "/admin/promotions"
@using QRDrinkOrder.Shared.DTOs.Responses
@using QRDrinkOrder.Shared.DTOs.Requests
@using QRDrinkOrder.Client.Services
@using System.Net.Http.Headers
@inject MenuApiClient MenuApi
@inject CouponApiClient CouponApi
@inject Microsoft.JSInterop.IJSRuntime JSRuntime
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Manager")]
@layout QRDrinkOrder.Client.Layout.AdminLayout

<PageTitle>Quản lý Tin tức / Khuyến mãi</PageTitle>

<div>
    <div class="admin-topbar">
        <div class="admin-topbar-left">
            <h1 class="admin-page-title">Quản lý Banner và Tin tức</h1>
            <p class="admin-page-subtitle">Cập nhật banner quảng cáo, tin tức khuyến mãi</p>
        </div>
        <div class="admin-topbar-right">
            <button class="btn-admin-action btn-action-primary" @onclick="() => OpenModal(null)">
                <i class="bi bi-plus-circle"></i> Thêm mới
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <div class="mt-2 text-muted">Đang tải dữ liệu...</div>
        </div>
    }
    else if (!promotions.Any())
    {
        <div class="alert alert-info">Chưa có tin tức/khuyến mãi nào.</div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var promo in promotions)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
                        <img src="@promo.ImageUrl" class="card-img-top" alt="@promo.Title" style="height: 180px; object-fit: cover;" onerror="this.onerror=null; this.src='https://placehold.co/600x400?text=No+Image';">
                        
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@promo.Title</h5>
                            <p class="card-text text-muted mb-2" style="font-size: 0.9rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @promo.Description
                            </p>
                            
                            @if (promo.CouponId.HasValue)
                            {
                                var cp = coupons.FirstOrDefault(c => c.CouponId == promo.CouponId);
                                if (cp != null)
                                {
                                    <span class="admin-badge badge-success mb-2">
                                        <i class="bi bi-ticket-perforated"></i> Đính kèm mã: @cp.CouponCode
                                    </span>
                                }
                            }
                            
                            <div class="mt-2">
                                <span class="admin-badge @(promo.IsActive ? "badge-primary" : "badge-secondary")">
                                    @(promo.IsActive ? "Đang hiển thị" : "Đã ẩn")
                                </span>
                            </div>
                        </div>
                        
                        <div class="card-footer bg-white border-0 d-flex justify-content-end gap-2 pb-3">
                            <button class="btn-admin-action btn-action-secondary btn-action-sm" @onclick="() => OpenModal(promo)">
                                <i class="bi bi-pencil"></i> Sửa
                            </button>
                            <button class="btn-admin-action btn-action-danger btn-action-sm" @onclick="() => DeletePromotion(promo.PromotionId)">
                                <i class="bi bi-trash"></i> Xóa
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Modal Thêm/Sửa Promotion -->
<div class="modal fade @(isModalOpen ? "show d-block" : "")" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">@(editingPromotionId == null ? "Thêm mới Tin tức/Khuyến mãi" : "Sửa Tin tức/Khuyến mãi")</h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            
            <div class="modal-body">
                <EditForm Model="promotionModel" OnValidSubmit="SavePromotion">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger mb-3" />

                    <div class="row">
                        <!-- Cột Trái: Ảnh và Trạng thái -->
                        <div class="col-md-5">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Ảnh Banner <span class="text-danger">*</span></label>
                                <InputFile class="form-control" OnChange="HandleImageUpload" accept="image/png, image/jpeg, image/webp" />
                                @if (isUploadingImage)
                                {
                                    <div class="mt-2 text-primary small">
                                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Đang tải ảnh lên...
                                    </div>
                                }
                                <ValidationMessage For="@(() => promotionModel.ImageUrl)" class="text-danger small mt-1" />
                            </div>
                            
                            @if (!string.IsNullOrEmpty(promotionModel.ImageUrl))
                            {
                                <div class="mb-3 border rounded overflow-hidden" style="height: 150px; background-color: #f8f9fa;">
                                    <img src="@promotionModel.ImageUrl" class="w-100 h-100" style="object-fit: cover;" onerror="this.onerror=null; this.src='https://placehold.co/600x400?text=No+Image';" />
                                </div>
                            }

                            <div class="mb-3">
                                <label class="form-label fw-bold">Trạng thái</label>
                                <div class="form-check form-switch">
                                    <InputCheckbox class="form-check-input" id="isActiveSwitch" @bind-Value="promotionModel.IsActive" />
                                    <label class="form-check-label" for="isActiveSwitch">Hiển thị lên Trang chủ</label>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Đính kèm Mã giảm giá (Tùy chọn)</label>
                                <InputSelect class="form-select" @bind-Value="promotionModel.CouponId">
                                    <option value="">-- Không đính kèm mã --</option>
                                    @foreach (var c in coupons)
                                    {
                                        <option value="@c.CouponId">@c.CouponCode (Giảm @(c.DiscountType == 0 ? c.DiscountValue.ToString("N0") + "đ" : c.DiscountValue.ToString() + "%"))</option>
                                    }
                                </InputSelect>
                                <div class="form-text">Dùng để tự động tặng mã hoặc khuyến khích khách lưu mã khi nhấn vào banner.</div>
                            </div>
                        </div>

                        <!-- Cột Phải: Tiêu đề và Nội dung -->
                        <div class="col-md-7">
                            <ul class="nav nav-tabs mb-3">
                                <li class="nav-item">
                                    <a class="nav-link @(activeTab == "vi" ? "active fw-bold text-primary" : "text-muted")" style="cursor: pointer;" @onclick="@(() => activeTab = "vi")">Tiếng Việt</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(activeTab == "en" ? "active fw-bold text-primary" : "text-muted")" style="cursor: pointer;" @onclick="@(() => activeTab = "en")">Tiếng Anh</a>
                                </li>
                            </ul>

                            @if (activeTab == "vi")
                            {
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Tiêu đề (VI) <span class="text-danger">*</span></label>
                                    <InputText class="form-control" @bind-Value="promotionModel.TitleVi" placeholder="VD: Mời bạn mới 50%" />
                                    <ValidationMessage For="@(() => promotionModel.TitleVi)" class="text-danger small" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Nội dung chi tiết (VI)</label>
                                    <InputTextArea class="form-control" @bind-Value="promotionModel.ContentVi" rows="5" placeholder="Mô tả chương trình khuyến mãi..." />
                                </div>
                            }
                            else
                            {
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Tiêu đề (EN) <span class="text-danger">*</span></label>
                                    <InputText class="form-control" @bind-Value="promotionModel.TitleEn" placeholder="e.g. 50% Off for New Friends" />
                                    <ValidationMessage For="@(() => promotionModel.TitleEn)" class="text-danger small" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Nội dung chi tiết (EN)</label>
                                    <InputTextArea class="form-control" @bind-Value="promotionModel.ContentEn" rows="5" placeholder="Promotion description..." />
                                </div>
                            }
                        </div>
                    </div>

                    <div class="modal-footer px-0 pb-0 mt-3 border-top-0">
                        <button type="button" class="btn btn-secondary" @onclick="CloseModal">Hủy</button>
                        <button type="submit" class="btn btn-primary" disabled="@isSaving">
                            @if (isSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                <span>Đang lưu...</span>
                            }
                            else
                            {
                                <span><i class="bi bi-save me-1"></i> Lưu thông tin</span>
                            }
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private bool isLoading = true;
    private bool isModalOpen = false;
    private bool isSaving = false;
    private bool isUploadingImage = false;
    private int? editingPromotionId = null;
    private string activeTab = "vi";

    private List<PromotionDto> promotions = new();
    private List<CouponDto> coupons = new();
    private SavePromotionRequest promotionModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            // Load all promotions (bằng cách lấy lang vi, tạm thời không lọc inactive vì api GetPromotionsAsync hiện đang chỉ trả về IsActive == true)
            // Wait, api đang chỉ trả về active! Tôi cần update api để admin thấy cả inactive?
            // Đã update: gọi với includeInactive = true
            promotions = await MenuApi.GetPromotionsAsync("vi", includeInactive: true);
            coupons = await CouponApi.GetAllCouponsAsync(includeInactive: false);
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Lỗi tải dữ liệu: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OpenModal(PromotionDto? promo)
    {
        activeTab = "vi";
        
        if (promo == null)
        {
            editingPromotionId = null;
            promotionModel = new SavePromotionRequest { IsActive = true };
        }
        else
        {
            editingPromotionId = promo.PromotionId;
            
            // Cần lấy full chi tiết cả EN và VI, do API get list chỉ trả 1 ngôn ngữ.
            // Để đơn giản, gán luôn bằng dữ liệu hiện có (thực tế cần API GetById trả full translations)
            var viPromo = await MenuApi.GetPromotionsAsync("vi", true); // Tạm bỏ qua tối ưu
            var enPromo = await MenuApi.GetPromotionsAsync("en", true);
            
            var v = viPromo.FirstOrDefault(p => p.PromotionId == promo.PromotionId);
            var e = enPromo.FirstOrDefault(p => p.PromotionId == promo.PromotionId);

            promotionModel = new SavePromotionRequest
            {
                ImageUrl = promo.ImageUrl,
                CouponId = promo.CouponId,
                IsActive = promo.IsActive,
                TitleVi = v?.Title ?? "",
                ContentVi = v?.Description,
                TitleEn = e?.Title ?? "",
                ContentEn = e?.Description
            };
        }
        
        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            try
            {
                isUploadingImage = true;

                // Max size: 5MB
                var maxAllowedSize = 5 * 1024 * 1024;
                using var stream = file.OpenReadStream(maxAllowedSize);
                
                var content = new MultipartFormDataContent();
                var fileContent = new StreamContent(stream);
                fileContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
                content.Add(fileContent, "file", file.Name);

                var imageUrl = await MenuApi.UploadImageAsync(content);
                
                if (!string.IsNullOrEmpty(imageUrl))
                {
                    promotionModel.ImageUrl = imageUrl;
                }
                else
                {
                    await JSRuntime.InvokeVoidAsync("alert", "Không thể tải lên ảnh!");
                }
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Lỗi tải ảnh: {ex.Message}");
            }
            finally
            {
                isUploadingImage = false;
            }
        }
    }

    private async Task SavePromotion()
    {
        try
        {
            isSaving = true;
            bool success;

            if (editingPromotionId == null)
            {
                success = await MenuApi.CreatePromotionAsync(promotionModel);
            }
            else
            {
                success = await MenuApi.UpdatePromotionAsync(editingPromotionId.Value, promotionModel);
            }

            if (success)
            {
                await LoadDataAsync();
                CloseModal();
                await JSRuntime.InvokeVoidAsync("alert", "Lưu tin tức/khuyến mãi thành công!");
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", "Có lỗi xảy ra khi lưu!");
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Lỗi: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeletePromotion(int id)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", "Bạn có chắc chắn muốn xóa tin tức/khuyến mãi này không?");
        if (confirm)
        {
            try
            {
                var success = await MenuApi.DeletePromotionAsync(id);
                if (success)
                {
                    await LoadDataAsync();
                }
                else
                {
                    await JSRuntime.InvokeVoidAsync("alert", "Lỗi khi xóa!");
                }
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Lỗi: {ex.Message}");
            }
        }
    }
}

@page "/admin/reviews"
@attribute [Authorize(Roles = "Admin,Manager")]
@layout QRDrinkOrder.Client.Layout.AdminLayout
@inject QRDrinkOrder.Client.Services.ReviewApiClient ReviewApi
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@using QRDrinkOrder.Shared.DTOs.Responses
@inject Microsoft.Extensions.Configuration.IConfiguration Config
<PageTitle>Đánh giá và Phản hồi - Ngoc UwU Coffee</PageTitle>

<div class="admin-topbar">
    <div class="admin-topbar-left">
        <h1 class="admin-page-title">Khách hàng và Đánh giá</h1>
        <p class="admin-page-subtitle">Quản lý phản hồi và nâng cao chất lượng dịch vụ</p>
    </div>
    
    <div class="dash-date-filter">
        <button class="dash-date-btn @(filterMode == 0 ? "active" : "")" @onclick="() => FilterReviews(0)">Tất cả</button>
        <button class="dash-date-btn @(filterMode == 5 ? "active" : "")" @onclick="() => FilterReviews(5)">5 Sao ⭐</button>
        <button class="dash-date-btn @(filterMode == 3 ? "active" : "")" @onclick="() => FilterReviews(3)">Dưới 3 Sao ⚠️</button>
    </div>
</div>

@if (isLoading)
{
    <div class="admin-loading">
        <div class="admin-loading-spinner"></div>
        <p>Đang tải danh sách đánh giá...</p>
    </div>
}
else if (filteredReviews == null || !filteredReviews.Any())
{
    <div class="admin-empty" style="padding: 4rem; text-align: center;">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
        <p>Chưa có đánh giá nào phù hợp với bộ lọc.</p>
    </div>
}
else
{
    <div class="review-grid">
        @foreach (var review in filteredReviews)
        {
            <div class="review-card @(review.Rating <= 3 ? "review-warning" : "")">
                <div class="review-card-header">
                    <div class="review-customer-info">
                        <div class="customer-avatar">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                            </svg>
                        </div>
                        <div class="customer-details">
                            <div class="customer-phone">
                                @(string.IsNullOrEmpty(review.CustomerPhone) ? "Khách ẩn danh" : review.CustomerPhone)
                            </div>
                            <div class="review-meta">
                                <span>Bàn @(review.TableNumber ?? "Mang đi")</span>
                                <span>•</span>
                                <span>Mã ĐH: #@review.OrderId</span>
                            </div>
                        </div>
                    </div>
                    <div class="review-date">@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>

                <div class="review-rating-wrap">
                    <div class="stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <svg class="star-icon @(i <= review.Rating ? "filled" : "")" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                            </svg>
                        }
                    </div>
                    @if (review.Rating <= 3)
                    {
                        <span class="badge-warning">Cần theo dõi</span>
                    }
                </div>

                <div class="review-content">
                    @if (string.IsNullOrWhiteSpace(review.Comment))
                    {
                        <span class="no-comment">Khách hàng không để lại bình luận.</span>
                    }
                    else
                    {
                        @review.Comment
                    }
                </div>

                @if (review.ImageUrls != null && review.ImageUrls.Any())
                {
                    <div class="review-images">
                        @foreach (var img in review.ImageUrls)
                        {
                            <img src="@(img.StartsWith("http") ? img : $"{backendUrl}{img}")" class="review-img-thumb" alt="Hình ảnh đánh giá" onerror="this.onerror=null; this.src='/images/placeholder.png';" />
                        }
                    </div>
                }

                @if (review.Rating <= 3 && !string.IsNullOrEmpty(review.CustomerPhone))
                {
                    <div class="review-actions">
                        <a href="tel:@review.CustomerPhone" class="btn-contact btn-call">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                            Gọi điện
                        </a>
                        <a href="https://zalo.me/@review.CustomerPhone" target="_blank" class="btn-contact btn-zalo">
                            Nhắn Zalo
                        </a>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private List<ReviewDto> allReviews = new();
    private List<ReviewDto> filteredReviews = new();
    private bool isLoading = true;
    private int filterMode = 0; // 0: All, 5: 5 sao, 3: Dưới 3 sao

    private string backendUrl = "";

    protected override async Task OnInitializedAsync()
    {
        backendUrl = (Config["BackendApiUrl"] ?? "http://localhost:5153").TrimEnd('/');
        isLoading = true;
        allReviews = await ReviewApi.GetAllReviewsAsync();
        ApplyFilter();
        isLoading = false;
    }

    private void FilterReviews(int mode)
    {
        filterMode = mode;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (filterMode == 5)
        {
            filteredReviews = allReviews.Where(r => r.Rating == 5).ToList();
        }
        else if (filterMode == 3)
        {
            filteredReviews = allReviews.Where(r => r.Rating <= 3).ToList();
        }
        else
        {
            filteredReviews = allReviews.ToList();
        }
    }
}

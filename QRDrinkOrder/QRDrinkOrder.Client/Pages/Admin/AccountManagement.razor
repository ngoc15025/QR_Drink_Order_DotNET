@page "/admin/accounts"
@attribute [Authorize(Roles = "Admin,Manager")]
@inject QRDrinkOrder.Client.Services.AuthApiClient AuthApi
@inject AuthenticationStateProvider AuthStateProvider
@using System.Security.Claims

@layout QRDrinkOrder.Client.Layout.AdminLayout

<PageTitle>Quản lý Tài khoản - Ngoc UwU Coffee</PageTitle>

<div>
    <div class="admin-topbar">
        <div class="admin-topbar-left">
            <h1 class="admin-page-title">
                @if (isAdmin)
                {
                    <span>Quản lý Tài khoản Quản lý</span>
                }
                else
                {
                    <span>Quản lý Tài khoản Nhân viên</span>
                }
            </h1>
            <p class="admin-page-subtitle">Quản lý và cấp quyền truy cập hệ thống</p>
        </div>
        <div class="admin-topbar-right">
            <button class="btn-admin-action btn-action-primary" @onclick="() => showCreateModal = true">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-lg" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2Z"/>
                </svg>
                Tạo tài khoản
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <div class="mt-2 text-secondary">Đang tải danh sách...</div>
        </div>
    }
    else
    {
        <div class="admin-table-card">
            <table class="admin-table">
                <thead>
                            <tr>
                                <th>Họ và tên</th>
                                <th>Email</th>
                                <th>Số điện thoại</th>
                                <th>Vai trò</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (filteredAccounts.Any())
                            {
                                @foreach (var acc in filteredAccounts)
                                {
                                    <tr>
                                        <td class="px-4 py-3 fw-bold">@acc.FullName</td>
                                        <td class="py-3">@acc.Email</td>
                                        <td class="py-3">@(string.IsNullOrEmpty(acc.Phone) ? "-" : acc.Phone)</td>
                                        <td class="py-3">
                                            <span class="admin-badge badge-secondary">@acc.RoleName</span>
                                        </td>
                                        <td class="py-3">
                                            @if (acc.IsActive)
                                            {
                                                <span class="admin-badge badge-success">Hoạt động</span>
                                            }
                                            else
                                            {
                                                <span class="admin-badge badge-danger">Đã khóa</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <button class="btn-admin-action btn-action-sm @(acc.IsActive ? "btn-action-danger" : "btn-action-success")" 
                                                    @onclick="() => ToggleStatus(acc.AccountId, !acc.IsActive)">
                                                @(acc.IsActive ? "Khóa" : "Mở khóa")
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-secondary">Không có tài khoản nào.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
        </div>
    }
</div>

<!-- Modal Tạo Tài Khoản -->
@if (showCreateModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Tạo tài khoản mới</h5>
                    <button type="button" class="btn-close" @onclick="() => showCreateModal = false"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@newAccount" OnValidSubmit="HandleCreate">
                        <DataAnnotationsValidator />
                        
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger py-2 small">@errorMessage</div>
                        }

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Họ và tên</label>
                            <InputText class="form-control" @bind-Value="newAccount.FullName" />
                            <ValidationMessage For="@(() => newAccount.FullName)" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Email đăng nhập</label>
                            <InputText class="form-control" @bind-Value="newAccount.Email" type="email" />
                            <ValidationMessage For="@(() => newAccount.Email)" class="text-danger small" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Số điện thoại</label>
                            <InputText class="form-control" @bind-Value="newAccount.Phone" type="tel" />
                            <ValidationMessage For="@(() => newAccount.Phone)" class="text-danger small" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold">Mật khẩu</label>
                            <InputText class="form-control" @bind-Value="newAccount.Password" type="password" />
                            <ValidationMessage For="@(() => newAccount.Password)" class="text-danger small" />
                        </div>
                        
                        <div class="d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-light" @onclick="() => showCreateModal = false">Hủy</button>
                            <button type="submit" class="btn btn-primary" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span> <span>Đang lưu...</span>
                                }
                                else
                                {
                                    <span>Tạo tài khoản</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isAdmin = false;
    private bool isLoading = true;
    private bool showCreateModal = false;
    private bool isSaving = false;
    private string errorMessage = "";
    
    private List<AccountDto> allAccounts = new();
    private List<AccountDto> filteredAccounts = new();
    
    private RegisterRequest newAccount = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var role = user.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role || c.Type == "role")?.Value;
        
        isAdmin = (role == "Admin");

        // Thiết lập roleId cần tạo tùy vào cấp quyền
        newAccount.RoleId = isAdmin ? (byte)2 : (byte)3; // 2 = Manager, 3 = Employee

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            allAccounts = await AuthApi.GetAllAccountsAsync();
            // Lọc danh sách hiển thị
            if (isAdmin)
            {
                filteredAccounts = allAccounts.Where(a => a.RoleId == 2).ToList(); // Chỉ xem Quản lý
            }
            else
            {
                filteredAccounts = allAccounts.Where(a => a.RoleId == 3).ToList(); // Chỉ xem Nhân viên
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleCreate()
    {
        isSaving = true;
        errorMessage = "";
        try
        {
            var success = await AuthApi.RegisterAsync(newAccount);
            if (success)
            {
                showCreateModal = false;
                newAccount = new RegisterRequest { RoleId = isAdmin ? (byte)2 : (byte)3 };
                await LoadData();
            }
            else
            {
                errorMessage = "Email này đã tồn tại hoặc có lỗi xảy ra.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Lỗi: " + ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ToggleStatus(int accountId, bool newStatus)
    {
        try
        {
            var success = await AuthApi.ToggleAccountStatusAsync(accountId, newStatus);
            if (success)
            {
                var acc = filteredAccounts.FirstOrDefault(a => a.AccountId == accountId);
                if (acc != null)
                {
                    acc.IsActive = newStatus;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }
}


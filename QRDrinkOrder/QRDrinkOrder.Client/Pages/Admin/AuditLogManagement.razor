@page "/admin/auditlogs"
@attribute [Authorize(Roles = "Admin,Manager")]
@inject QRDrinkOrder.Client.Services.AuditLogApiClient AuditLogApi

@layout QRDrinkOrder.Client.Layout.AdminLayout

<PageTitle>Nhật ký hệ thống - Ngoc UwU Coffee</PageTitle>

<div>
    <div class="admin-topbar">
        <div class="admin-topbar-left">
            <h1 class="admin-page-title">Nhật ký Hệ thống (Audit Logs)</h1>
            <p class="admin-page-subtitle">Theo dõi các hoạt động thay đổi dữ liệu của tài khoản</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <div class="mt-2 text-secondary">Đang tải dữ liệu...</div>
        </div>
    }
    else
    {
        <div class="admin-table-card">
            <div class="table-responsive">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th style="width: 15%">Thời gian</th>
                            <th style="width: 25%">Người thực hiện</th>
                            <th style="width: 15%">Hành động</th>
                            <th style="width: 20%">Bảng / Chức năng</th>
                            <th style="width: 25%">Mô tả</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (logs.Any())
                        {
                            @foreach (var log in logs)
                            {
                                <tr>
                                    <td class="py-3 text-secondary small">
                                        @(log.CreatedAt?.ToString("dd/MM/yyyy HH:mm:ss") ?? "-")
                                    </td>
                                    <td class="py-3">
                                        <div class="fw-bold">@(log.FullName ?? "Hệ thống")</div>
                                        <div class="small text-secondary">@(log.Email ?? "")</div>
                                    </td>
                                    <td class="py-3">
                                        @if (log.Action == "INSERT")
                                        {
                                            <span class="admin-badge badge-success">Thêm mới</span>
                                        }
                                        else if (log.Action == "UPDATE")
                                        {
                                            <span class="admin-badge badge-warning">Cập nhật</span>
                                        }
                                        else if (log.Action == "DELETE")
                                        {
                                            <span class="admin-badge badge-danger">Xóa</span>
                                        }
                                        else
                                        {
                                            <span class="admin-badge badge-secondary">@log.Action</span>
                                        }
                                    </td>
                                    <td class="py-3">
                                        <span class="admin-badge" style="background: rgba(var(--bs-primary-rgb), 0.1); color: var(--bs-primary)">
                                            @(log.TableName ?? "-")
                                        </span>
                                    </td>
                                    <td class="py-3 text-secondary small" style="word-break: break-word; max-width: 300px;">
                                        @(string.IsNullOrEmpty(log.Description) ? $"ID Tài khoản: {log.AccountId?.ToString() ?? "N/A"}" : log.Description)
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-secondary">Không có nhật ký nào.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Phân trang cơ bản -->
            <div class="d-flex justify-content-between align-items-center mt-4">
                <div class="text-secondary small">
                    Tổng số: <strong>@totalCount</strong> bản ghi
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-secondary" disabled="@(currentPage == 1)" @onclick="() => LoadData(currentPage - 1)">Trang trước</button>
                    <span class="btn btn-sm btn-light disabled">Trang @currentPage</span>
                    <button class="btn btn-sm btn-outline-secondary" disabled="@(logs.Count < pageSize)" @onclick="() => LoadData(currentPage + 1)">Trang sau</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<QRDrinkOrder.Shared.DTOs.Responses.AuditLogDto> logs = new();
    
    private int currentPage = 1;
    private int pageSize = 20;
    private int totalCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData(1);
    }

    private async Task LoadData(int page)
    {
        isLoading = true;
        currentPage = page;
        
        try
        {
            var response = await AuditLogApi.GetAuditLogsAsync(currentPage, pageSize);
            if (response != null)
            {
                logs = response.Items;
                totalCount = response.TotalCount;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading audit logs: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}
